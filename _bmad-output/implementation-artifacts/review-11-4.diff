diff --git a/tests/Hexalith.Parties.CommandApi.Tests/Controllers/PartiesControllerTenantAuthorizationTests.cs b/tests/Hexalith.Parties.CommandApi.Tests/Controllers/PartiesControllerTenantAuthorizationTests.cs
