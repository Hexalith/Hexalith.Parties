--- /dev/null
+++ b/deploy/dapr/subscription-tenants.yaml
@@ -0,0 +1,23 @@
+# DAPR Declarative Subscription -- Hexalith.Tenants Events
+# ====================================================================
+# Routes authoritative tenant lifecycle, membership, role, and
+# configuration events from Hexalith.Tenants into Parties' local access
+# projection. Parties consumes this state; it does not manage tenant state.
+apiVersion: dapr.io/v2alpha1
+kind: Subscription
+metadata:
+  name: hexalith-parties-tenants-events-parties
+  annotations:
+    # DAPR subscription schema keeps delivery retry policy in resiliency.yaml.
+    # This annotation names the expected inbound policy so reviewers/operators can
+    # verify dead-letter delivery has bounded retries before poison routing.
+    hexalith.io/resiliency-policy: pubsubRetryInbound
+    hexalith.io/max-deliveries: "20"
+spec:
+  pubsubname: pubsub
+  topic: "system.tenants.events"
+  routes:
+    default: /events/tenants
+  deadLetterTopic: "deadletter.system.tenants.events"
+scopes:
+  - parties
