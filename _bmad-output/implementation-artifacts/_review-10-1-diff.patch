+        PartiesAdminPortalApiClient client = CreateClient(handler);
+
+        AdminPortalQueryResult<PagedResult<PartyIndexEntry>> result = await client.ListPartiesAsync(
+            new AdminPortalListRequest(1, 20, null, null),
