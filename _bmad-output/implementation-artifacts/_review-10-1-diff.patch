+
+    public CancellationToken ScopeCancellationToken => _scopeCts.Token;
+
+    public void ResetForTenantSwitch()
+    {
+        CancellationTokenSource old = Interlocked.Exchange(ref _scopeCts, new CancellationTokenSource());
