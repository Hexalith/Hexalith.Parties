@@ -0,0 +1,30 @@
+<section aria-labelledby="@($"dpo-summary-heading-{InstanceId}")">
+    <h4 id="@($"dpo-summary-heading-{InstanceId}")">@Labels.GdprOperationalSummary</h4>
+    <dl>
+        <dt>@Labels.GdprDpoPendingErasure</dt>
+        <dd>@(IsErasurePending ? Labels.Yes : Labels.No)</dd>
+        <dt>@Labels.GdprDpoRestricted</dt>
+        <dd>@(Party.IsRestricted ? Labels.Yes : Labels.No)</dd>
+        <dt>@Labels.GdprDpoConsentOverview</dt>
+        <dd>@Party.ConsentRecords.Count</dd>
+        <dt>@Labels.GdprDpoAuditTrail</dt>
+        <dd>@ProcessingRecordCount</dd>
+    </dl>
+</section>
+
+@code {
+    [Parameter, EditorRequired]
+    public PartyDetail Party { get; set; } = default!;
+
+    [Parameter, EditorRequired]
+    public AdminPortalLabels Labels { get; set; } = new();
+
+    [Parameter]
+    public string InstanceId { get; set; } = Guid.NewGuid().ToString("N");
+
+    [Parameter]
+    public bool IsErasurePending { get; set; }
+
+    [Parameter]
+    public int ProcessingRecordCount { get; set; }
+}
diff --git a/src/Hexalith.Parties.AdminPortal/Components/ErasureStatusPanel.razor b/src/Hexalith.Parties.AdminPortal/Components/ErasureStatusPanel.razor
new file mode 100644
index 0000000..c55ae19
--- /dev/null
+++ b/src/Hexalith.Parties.AdminPortal/Components/ErasureStatusPanel.razor
@@ -0,0 +1,45 @@
+<section aria-labelledby="@($"erasure-status-heading-{InstanceId}")">
+    <h4 id="@($"erasure-status-heading-{InstanceId}")">@Labels.GdprErasureStatus</h4>
+    @if (Status is null)
+    {
+        <p>@Labels.GdprCertificateUnavailable</p>
+    }
+    else
+    {
+        <dl>
+            <dt>@Labels.Status</dt>
+            <dd>@Status.Status</dd>
+            <dt>@Labels.GdprUpdatedAt</dt>
+            <dd>@FormatDate(Status.UpdatedAt)</dd>
+            <dt>@Labels.ErasedAt</dt>
+            <dd>@FormatOptionalDate(Status.ErasedAt)</dd>
+        </dl>
+    }
+
+    <section aria-labelledby="@($"erasure-report-heading-{InstanceId}")">
+        <h5 id="@($"erasure-report-heading-{InstanceId}")">@Labels.GdprCertificate</h5>
+        <ErasureVerificationReportPanel Certificate="Certificate" Labels="Labels" />
+    </section>
+</section>
+
+@code {
+    [Parameter, EditorRequired]
+    public PartyErasureStatusRecord? Status { get; set; }
+
+    [Parameter, EditorRequired]
+    public ErasureCertificate? Certificate { get; set; }
+
+    [Parameter, EditorRequired]
+    public AdminPortalLabels Labels { get; set; } = new();
+
+    [Parameter]
+    public string InstanceId { get; set; } = Guid.NewGuid().ToString("N");
+
+    private string FormatOptionalDate(DateTimeOffset? date)
+        => date is null ? Labels.MissingDate : FormatDate(date.Value);
+
+    private string FormatDate(DateTimeOffset date)
+        => date == default
+            ? Labels.MissingDate
+            : date.ToString("g", System.Globalization.CultureInfo.CurrentCulture);
+}
