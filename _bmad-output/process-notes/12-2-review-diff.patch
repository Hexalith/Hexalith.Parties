-                        partyId,
-                        nameof(CompletePartyErasure),
-                        new CompletePartyErasure {
-                            PartyId = partyId,
-                            TenantId = tenantId,
-                            ErasedAt = erasedAt,
-                        },
-                        correlationId,
-                        userId,
