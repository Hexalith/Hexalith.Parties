-                    }).ConfigureAwait(false);
-                    return;
-                }
-
-                // Phase 3: Verification
-                ErasureVerificationReport report = await erasureOrchestrator
-                    .ExecuteVerificationAsync(tenantId, partyId, certificate, CancellationToken.None)
-                    .ConfigureAwait(false);
