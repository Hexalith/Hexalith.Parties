@inject PartyPickerApiClient ApiClient
@inject IJSRuntime JsRuntime
@implements IAsyncDisposable

<section id="@_hostElementId" class="hx-party-picker" data-state="@_search.State.ToString().ToLowerInvariant()">
    <label class="hx-party-picker__label" for="@_inputElementId">@EffectiveLabels.SearchLabel</label>
    <div class="hx-party-picker__input-row">
        <input id="@_inputElementId"
               @ref="_inputElement"
               class="hx-party-picker__input"
               value="@_query"
               placeholder="@EffectiveLabels.Placeholder"
               aria-label="@EffectiveLabels.SearchLabel"
               aria-controls="@_listElementId"
               aria-readonly="@(ReadOnly ? "true" : null)"
               readonly="@(ReadOnly ? "readonly" : null)"
               disabled="@(Disabled ? "disabled" : null)"
               @oninput="HandleInputAsync" />
        <button type="button"
                class="hx-party-picker__icon-button"
                disabled="@(IsInteractionDisabled || (_selected is null && string.IsNullOrWhiteSpace(_query)))"
                aria-label="@EffectiveLabels.ClearSelection"
                title="@EffectiveLabels.ClearSelection"
                @onclick="ClearAsync"><span class="hx-party-picker__icon" aria-hidden="true">&times;</span></button>
    </div>

    @if (_selected is not null)
    {
        <div class="hx-party-picker__selected" aria-label="@EffectiveLabels.Selected">
            <span class="hx-party-picker__selected-name">@SelectionDisplayText(_selected)</span>
            @if (HasSelectionStatus(_selected))
            {
                <span class="hx-party-picker__badge">@StatusText(_selected)</span>
            }
        </div>
    }

    <div class="hx-party-picker__status" role="status" aria-live="polite">
        @StatusMessage
    </div>

    @if (CanRetry)
    {
        <button type="button" class="hx-party-picker__retry" @onclick="RetryAsync">@EffectiveLabels.Retry</button>
    }

    @if (_search.HasResults)
    {
        <ul id="@_listElementId" class="hx-party-picker__results" role="listbox" aria-label="@EffectiveLabels.SearchLabel">
            @foreach (PartySearchResult result in _search.Results)
            {
                <li class="hx-party-picker__result" role="option" aria-selected="@IsSelected(result)">
                    <button type="button"
                            class="hx-party-picker__result-button"
                            disabled="@IsInteractionDisabled"
                            @onclick="() => SelectAsync(result)">
                        @if (ResultTemplate is not null)
                        {
                            @ResultTemplate(result)
                        }
                        else
                        {
                            <span class="hx-party-picker__result-main">
                                <span class="hx-party-picker__result-name">@result.Party.DisplayName</span>
                                <span class="hx-party-picker__result-type">@result.Party.Type</span>
                            </span>
                            <span class="hx-party-picker__result-status">
                                <span class="hx-party-picker__badge">@StatusText(result.Party)</span>
                            </span>
                        }
                    </button>
                </li>
            }
        </ul>
    }
</section>

@code {
    private readonly TimeSpan _defaultDebounce = TimeSpan.FromMilliseconds(PartyPickerDefaults.DebounceMilliseconds);
    private CancellationTokenSource? _searchCts;
    private IJSObjectReference? _module;
    private ElementReference _inputElement;
    private string _query = string.Empty;
    private PartyPickerSearchResponse _search = new() { State = PartyPickerSearchState.Idle, PageSize = PartyPickerDefaults.PageSize };
    private PartyPickerSelection? _selected;
    private string? _previousContextSignature;
    private long _searchVersion;
    private readonly string _hostElementId = $"hx-party-picker-{Guid.NewGuid():N}";
    private readonly string _inputElementId = $"hx-party-picker-input-{Guid.NewGuid():N}";
    private readonly string _listElementId = $"hx-party-picker-list-{Guid.NewGuid():N}";

    [Obsolete("ApiBaseUrl no longer controls picker transport. Configure the EventStore gateway base URL through Hexalith.Parties.Client (PartiesClientOptions). This parameter will be removed in a future major release.")]
    [Parameter]
    public string? ApiBaseUrl { get; set; }

    [Parameter]
    public string? AccessToken { get; set; }

    [Parameter]
    public Func<CancellationToken, ValueTask<string?>>? AccessTokenProvider { get; set; }

    [Parameter]
    public Func<HttpRequestMessage, CancellationToken, ValueTask>? RequestCustomizer { get; set; }

    [Parameter]
    public string? ContextKey { get; set; }

    [Parameter]
    public string? AuthContextKey { get; set; }

    [Parameter]
    public string? SelectedPartyId { get; set; }

    [Parameter]
    public EventCallback<PartyPickerSelection?> SelectedPartyChanged { get; set; }

    [Parameter]
    public int PageSize { get; set; } = PartyPickerDefaults.PageSize;

    [Parameter]
    public string? SearchMode { get; set; }

    [Parameter]
    public string? CaseId { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public int DebounceMilliseconds { get; set; } = PartyPickerDefaults.DebounceMilliseconds;

    [Parameter]
    public PartyPickerLabels? Labels { get; set; }

    [Parameter]
    public RenderFragment<PartySearchResult>? ResultTemplate { get; set; }

    [Parameter]
    public bool DispatchDomEvents { get; set; } = true;

    private PartyPickerLabels EffectiveLabels => Labels ?? new PartyPickerLabels();

    private bool IsInteractionDisabled => Disabled || ReadOnly;

    private bool CanRetry
        => !IsInteractionDisabled
            && !string.IsNullOrWhiteSpace(_query)
            && (_search.State is PartyPickerSearchState.TransientFailure or PartyPickerSearchState.Error);

    private string StatusMessage
        => _search.State switch
        {
            PartyPickerSearchState.Loading => EffectiveLabels.Loading,
            PartyPickerSearchState.AuthenticationRequired => EffectiveLabels.AuthenticationRequired,
            PartyPickerSearchState.Empty => EffectiveLabels.Empty,
            PartyPickerSearchState.LocalOnly => EffectiveLabels.LocalOnly,
            PartyPickerSearchState.Degraded => EffectiveLabels.Degraded,
            PartyPickerSearchState.Unauthorized => EffectiveLabels.Unauthorized,
            PartyPickerSearchState.Forbidden => EffectiveLabels.Forbidden,
            PartyPickerSearchState.TransientFailure => EffectiveLabels.TransientFailure,
            PartyPickerSearchState.NotFound or PartyPickerSearchState.Gone => EffectiveLabels.Empty,
            PartyPickerSearchState.Error => EffectiveLabels.Error,
            _ => string.Empty,
        };

    protected override void OnParametersSet()
    {
        string signature = string.Join(
            "|",
            ContextKey,
            AuthContextKey,
            SearchMode,
            CaseId,
            PageSize.ToString(System.Globalization.CultureInfo.InvariantCulture),
            Disabled.ToString(),
            ReadOnly.ToString(),
            TokenFingerprint(AccessToken),
            string.IsNullOrEmpty(AuthContextKey) ? DelegateFingerprint(AccessTokenProvider) : "auth-key",
            string.IsNullOrEmpty(AuthContextKey) ? DelegateFingerprint(RequestCustomizer) : "auth-key");

        if (_previousContextSignature is not null && !string.Equals(_previousContextSignature, signature, StringComparison.Ordinal))
        {
            ResetEphemeralState();
        }

        _previousContextSignature = signature;

        if (string.IsNullOrWhiteSpace(SelectedPartyId))
        {
            _selected = null;
        }
        else if (_selected?.PartyId != SelectedPartyId)
        {
            _selected = new PartyPickerSelection { PartyId = SelectedPartyId };
        }
    }

    private async Task HandleInputAsync(ChangeEventArgs args)
    {
        if (IsInteractionDisabled)
        {
            return;
        }

        _query = args.Value?.ToString() ?? string.Empty;
        _selected = null;
        await SelectedPartyChanged.InvokeAsync(null).ConfigureAwait(false);

        await ScheduleSearchAsync().ConfigureAwait(false);
    }

    private async Task ScheduleSearchAsync()
    {
        CancelPendingSearch();

        if (string.IsNullOrWhiteSpace(_query))
        {
            _search = new PartyPickerSearchResponse
            {
                State = PartyPickerSearchState.Idle,
                PageSize = PartyPickerApiClient.BoundPageSize(PageSize),
            };
            return;
        }

        _search = _search with { State = PartyPickerSearchState.Loading, Results = [] };
        long version = ++_searchVersion;
        _searchCts = new CancellationTokenSource();
        CancellationToken token = _searchCts.Token;

        try
        {
            TimeSpan delay = TimeSpan.FromMilliseconds(Math.Max(0, DebounceMilliseconds));
            await Task.Delay(delay == TimeSpan.Zero ? _defaultDebounce : delay, token).ConfigureAwait(false);
            PartyPickerSearchResponse response = await ApiClient.SearchAsync(CreateRequest(), token).ConfigureAwait(false);
            if (version == _searchVersion && !token.IsCancellationRequested)
            {
                _search = response;
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private PartyPickerSearchRequest CreateRequest()
        => new()
        {
            Query = _query,
            Page = 1,
            PageSize = PageSize,
            Mode = ParseMode(SearchMode),
            CaseId = CaseId,
            AccessTokenProvider = AccessTokenProvider ?? (string.IsNullOrWhiteSpace(AccessToken) ? null : ResolveAccessTokenAsync),
            RequestCustomizer = RequestCustomizer,
        };

    private ValueTask<string?> ResolveAccessTokenAsync(CancellationToken cancellationToken)
    {
        cancellationToken.ThrowIfCancellationRequested();
        return ValueTask.FromResult(AccessToken);
    }

    private static string TokenFingerprint(string? token)
        => string.IsNullOrWhiteSpace(token)
            ? "none"
            : StringComparer.Ordinal.GetHashCode(token).ToString(System.Globalization.CultureInfo.InvariantCulture);

    private static string DelegateFingerprint(Delegate? handler)
        => handler is null
            ? "none"
            : System.Runtime.CompilerServices.RuntimeHelpers.GetHashCode(handler)
                .ToString(System.Globalization.CultureInfo.InvariantCulture);

    private async Task RetryAsync()
    {
        if (!string.IsNullOrWhiteSpace(_query))
        {
            await ScheduleSearchAsync().ConfigureAwait(false);
        }
    }

    private async Task SelectAsync(PartySearchResult result)
    {
        _selected = new PartyPickerSelection
        {
            PartyId = result.Party.Id,
            DisplayName = result.Party.DisplayName,
            PartyType = result.Party.Type,
            IsActive = result.Party.IsActive,
            IsErased = result.Party.IsErased,
        };

        await SelectedPartyChanged.InvokeAsync(_selected).ConfigureAwait(false);
        await DispatchSelectedDomEventAsync(_selected).ConfigureAwait(false);
        await TryFocusInputAsync().ConfigureAwait(false);
    }

    private async Task ClearAsync()
    {
        if (IsInteractionDisabled)
        {
            return;
        }

        CancelPendingSearch();
        _query = string.Empty;
        _selected = null;
        _search = new PartyPickerSearchResponse
        {
            State = PartyPickerSearchState.Idle,
            PageSize = PartyPickerApiClient.BoundPageSize(PageSize),
        };
        await SelectedPartyChanged.InvokeAsync(null).ConfigureAwait(false);
        await TryFocusInputAsync().ConfigureAwait(false);
    }

    private async Task DispatchSelectedDomEventAsync(PartyPickerSelection selection)
    {
        if (!DispatchDomEvents)
        {
            return;
        }

        try
        {
            _module ??= await JsRuntime
                .InvokeAsync<IJSObjectReference>(
                    "import",
                    "./_content/Hexalith.Parties.Picker/hexalith-parties-picker.js")
                .ConfigureAwait(false);
            await _module.InvokeVoidAsync("dispatchPartySelected", _hostElementId, PartyPickerEventDetail.FromSelection(selection)).ConfigureAwait(false);
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void ResetEphemeralState()
    {
        CancelPendingSearch();
        _query = string.Empty;
        _selected = null;
        _search = new PartyPickerSearchResponse
        {
            State = PartyPickerSearchState.Idle,
            PageSize = PartyPickerApiClient.BoundPageSize(PageSize),
        };
    }

    private void CancelPendingSearch()
    {
        _searchVersion++;
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _searchCts = null;
    }

    private async Task TryFocusInputAsync()
    {
        try
        {
            await _inputElement.FocusAsync().ConfigureAwait(false);
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private static PartyPickerSearchMode? ParseMode(string? mode)
        => mode?.Trim().ToLowerInvariant() switch
        {
            "lexical" or "syntactic" => PartyPickerSearchMode.Lexical,
            "semantic" => PartyPickerSearchMode.Semantic,
            "hybrid" => PartyPickerSearchMode.Hybrid,
            _ => null,
        };

    private bool IsSelected(PartySearchResult result)
        => string.Equals(_selected?.PartyId, result.Party.Id, StringComparison.Ordinal);

    private static bool HasSelectionStatus(PartyPickerSelection selection)
        => selection.IsActive.HasValue || selection.IsErased.HasValue;

    private static string SelectionDisplayText(PartyPickerSelection selection)
        => string.IsNullOrWhiteSpace(selection.DisplayName)
            ? selection.PartyId ?? string.Empty
            : selection.DisplayName;

    private string StatusText(PartyPickerSelection selection)
        => selection.IsErased == true
            ? EffectiveLabels.Erased
            : selection.IsActive == false
                ? EffectiveLabels.Inactive
                : EffectiveLabels.Active;

    private string StatusText(PartyIndexEntry party)
        => party.IsErased
            ? EffectiveLabels.Erased
            : party.IsActive
                ? EffectiveLabels.Active
                : EffectiveLabels.Inactive;

    public async ValueTask DisposeAsync()
    {
        CancelPendingSearch();
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync().ConfigureAwait(false);
            }
            catch (JSDisconnectedException)
            {
            }
            catch (JSException)
            {
            }
        }
    }
}
