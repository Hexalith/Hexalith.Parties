@page "/admin"
@attribute [Authorize(Policy = PartiesUiAuthorization.AdminPolicy)]
@inject NavigationManager Nav

@*
    Story 2.1 — protected compatibility entry point for /admin. Authorization is enforced by
    AuthorizeRouteView before this component runs; authorized admins are sent to the embedded
    AdminPortal entry point.
*@

<h1>Administration</h1>
<p><a href="@Hexalith.Parties.AdminPortal.Services.PartiesAdminPortalManifest.Route">Open Parties</a></p>

@code {
    protected override void OnInitialized()
        => Nav.NavigateTo(Hexalith.Parties.AdminPortal.Services.PartiesAdminPortalManifest.Route);
}
