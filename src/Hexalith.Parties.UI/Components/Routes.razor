<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData">
            @* Story 1.3 — AuthorizeRouteView (not plain RouteView) so [Authorize(Policy = …)] on the
               /admin and /me area pages is actually enforced; RouteView ignores those attributes. *@
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                <NotAuthorized Context="authState">
                    @if (authState.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToChallenge />
                    }
                    else
                    {
                        <h1>Access denied</h1>
                        <p>You are not authorized to view this area.</p>
                    }
                </NotAuthorized>
                <Authorizing>
                    <p role="status" aria-live="polite">Authorizing…</p>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>
