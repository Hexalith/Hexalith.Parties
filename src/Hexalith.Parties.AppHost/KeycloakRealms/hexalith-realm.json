{
  "realm": "hexalith",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 3600,
  "roles": {
    "realm": [
      { "name": "Admin", "description": "Parties administrators — land in the Admin area." },
      { "name": "TenantOwner", "description": "Tenant owners — land in the Admin area." },
      { "name": "Consumer", "description": "Self-service consumers — land in the Consumer area." }
    ]
  },
  "clients": [
    {
      "clientId": "hexalith-parties",
      "name": "Hexalith Parties",
      "description": "Parties API client for local development and documentation quickstarts",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "hexalith-parties",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "tenants-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenants",
            "claim.name": "eventstore:tenant",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "aggregate.attrs": "true"
          }
        },
        {
          "name": "domains-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "domains",
            "claim.name": "eventstore:domain",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "aggregate.attrs": "true"
          }
        },
        {
          "name": "permissions-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "permissions",
            "claim.name": "eventstore:permission",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "aggregate.attrs": "true"
          }
        }
      ]
    },
    {
      "clientId": "hexalith-eventstore",
      "name": "Hexalith EventStore",
      "description": "EventStore Admin API client for local development and documentation quickstarts",
      "enabled": true,
