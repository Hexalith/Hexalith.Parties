@page "/me/privacy"
@attribute [Authorize(Policy = PartiesRoles.ConsumerPolicy)]
@implements IDisposable
@using Hexalith.Parties.Contracts.Authorization
@using Microsoft.JSInterop

@inject IConsumerPrivacyExportClient ExportClient
@inject IConsumerPrivacyErasureClient ErasureClient
@inject IConsumerPrivacyProcessingClient ProcessingClient
@inject IJSRuntime JsRuntime

<section class="hx-parties-profile hx-parties-privacy" aria-labelledby="@_titleId">
    <header class="hx-parties-profile__header">
        <p class="hx-parties-profile__eyebrow">@ConsumerPortalLabels.AreaLabel</p>
        <h1 id="@_titleId">@ConsumerPortalLabels.PrivacyTitle</h1>
        <p class="hx-parties-profile__summary">@ConsumerPortalLabels.PrivacySummary</p>
        @if (!_failureVisible)
        {
            <p class="hx-parties-profile__freshness" role="status" aria-live="polite">@StatusMessage</p>
        }
    </header>

    <div class="hx-parties-profile__content">
        <section class="hx-parties-profile__section hx-parties-privacy__export" aria-labelledby="@_exportId">
            <div class="hx-parties-privacy__section-header">
                <h2 id="@_exportId">@ConsumerPortalLabels.PrivacyExportTitle</h2>
                <p class="hx-parties-privacy__format">@ConsumerPortalLabels.PrivacyExportFormat</p>
            </div>
            <p>@ConsumerPortalLabels.PrivacyExportDescription</p>

            @if (_failureVisible)
            {
                <div class="hx-parties-profile__notice" role="alert" aria-labelledby="@_failureId">
                    <h3 id="@_failureId">@ConsumerPortalLabels.PrivacyExportFailureTitle</h3>
                    <p>@ConsumerPortalLabels.PrivacyExportFailureMessage</p>
                </div>
            }

            <div class="hx-parties-privacy__actions">
                <FluentButton Appearance="ButtonAppearance.Primary"
                              Disabled="@_isPreparing"
                              OnClick="PrepareExportAsync">
                    @ConsumerPortalLabels.PrivacyExportAction
                </FluentButton>

                @if (CanDownload)
                {
                    <FluentButton Appearance="ButtonAppearance.Outline"
                                  Disabled="@_isDownloading"
                                  OnClick="DownloadAsync">
                        @ConsumerPortalLabels.PrivacyExportDownload
                    </FluentButton>
                }
            </div>
        </section>

        <section class="hx-parties-profile__section hx-parties-privacy__processing" aria-labelledby="@_processingId">
            <div class="hx-parties-privacy__section-header">
                <h2 id="@_processingId">@ConsumerPortalLabels.PrivacyProcessingTitle</h2>
            </div>
            <p>@ConsumerPortalLabels.PrivacyProcessingDescription</p>
            <p class="hx-parties-profile__freshness">@ConsumerPortalLabels.PrivacyProcessingBoundedMetadata</p>

            @if (ShowProcessingAlert)
            {
                <div class="hx-parties-profile__notice" role="alert" aria-labelledby="@_processingFailureId">
                    <h3 id="@_processingFailureId">@ConsumerPortalLabels.PrivacyProcessingFailureTitle</h3>
                    <p>@ProcessingAlertMessage</p>
                </div>
            }
            else
            {
                <p class="hx-parties-profile__freshness" role="status" aria-live="polite">@ProcessingStatusMessage</p>
            }

            @if (!_isLoadingProcessing && _processing.Records.Count > 0)
            {
                <ul class="hx-parties-privacy__processing-list">
                    @foreach (ConsumerPrivacyProcessingRecord record in _processing.Records)
                    {
                        <li class="hx-parties-privacy__processing-item">
                            <div class="hx-parties-privacy__processing-meta">
                                <span>@ConsumerPortalLabels.PrivacyProcessingCategoryLabel(record.Category)</span>
                                <span>@ConsumerPortalLabels.PrivacyProcessingOutcomeLabel(record.Outcome)</span>
                            </div>
                            <p>@SafeProcessingSummary(record)</p>
                            <p class="hx-parties-profile__freshness">@ConsumerPortalLabels.FormatPrivacyProcessingTimestamp(record.Timestamp)</p>
                        </li>
                    }
                </ul>
            }

            <p>@ConsumerPortalLabels.PrivacyProcessingConsentSummary</p>
            <a class="hx-parties-privacy__consent-link" href="/me/consent">@ConsumerPortalLabels.PrivacyProcessingManageConsent</a>
        </section>

        <section class="hx-parties-profile__section hx-parties-privacy__erasure" aria-labelledby="@_erasureId">
            <h2 id="@_erasureId">@ConsumerPortalLabels.PrivacyErasureTitle</h2>
            <p>@ConsumerPortalLabels.PrivacyErasureDescription</p>

            @if (_erasureAlertVisible)
            {
                <div class="hx-parties-profile__notice" role="alert" aria-labelledby="@_erasureFailureId">
                    <h3 id="@_erasureFailureId">@ConsumerPortalLabels.PrivacyErasureFailureTitle</h3>
                    <p>@ErasureAlertMessage</p>
                </div>
            }
            else if (ShowErasureStatus)
            {
                <p class="hx-parties-profile__freshness" role="status" aria-live="polite">@ErasureStatusMessage</p>
            }
            else
            {
                <p class="hx-parties-profile__freshness">@ErasureStatusMessage</p>
            }

            @if (_confirmErasure)
            {
                <div class="hx-parties-profile__notice" role="dialog" aria-modal="true" aria-labelledby="@_erasureConfirmId">
                    <h3 id="@_erasureConfirmId">@ConsumerPortalLabels.PrivacyErasureConfirmTitle</h3>
                    <p>@ConsumerPortalLabels.PrivacyErasureConfirmMessage</p>
                    <div class="hx-parties-privacy__actions">
                        <FluentButton Appearance="ButtonAppearance.Outline"
                                      Disabled="@_erasureBusy"
                                      OnClick="DismissErasureConfirmation">
                            @ConsumerPortalLabels.PrivacyErasureKeepData
                        </FluentButton>
                        <FluentButton Appearance="ButtonAppearance.Outline"
                                      class="hx-parties-privacy__danger-action"
                                      Disabled="@_erasureBusy"
                                      OnClick="RequestErasureAsync">
                            @ConsumerPortalLabels.PrivacyErasureConfirmAction
                        </FluentButton>
                    </div>
                </div>
            }

            <div class="hx-parties-privacy__actions">
                @if (CanRequestErasure)
                {
                    <FluentButton Appearance="ButtonAppearance.Outline"
                                  class="hx-parties-privacy__danger-action"
                                  Disabled="@_erasureBusy"
                                  OnClick="BeginErasureConfirmation">
                        @ConsumerPortalLabels.PrivacyErasureAction
                    </FluentButton>
                }
                else if (CanCancelErasure)
                {
                    <FluentButton Appearance="ButtonAppearance.Outline"
                                  Disabled="@_erasureBusy"
                                  OnClick="CancelErasureAsync">
                        @ConsumerPortalLabels.PrivacyErasureCancelAction
                    </FluentButton>
                }
                else if (ShowDisabledCancel)
                {
                    <FluentButton Appearance="ButtonAppearance.Outline"
                                  Disabled="true"
                                  aria-disabled="true">
                        @ConsumerPortalLabels.PrivacyErasureCancelAction
                    </FluentButton>
                    <p>@ConsumerPortalLabels.PrivacyErasureCancelUnavailable</p>
                }
            </div>
        </section>
    </div>
</section>

@code {
    private static int s_nextInstanceId;

    private readonly int _instanceId = System.Threading.Interlocked.Increment(ref s_nextInstanceId);
    private CancellationTokenSource? _exportCts;
    private CancellationTokenSource? _erasureCts;
    private CancellationTokenSource? _processingCts;
    private ConsumerPrivacyExportResult? _download;
    private ConsumerPrivacyErasureResult _erasure = ConsumerPrivacyErasureResult.Active();
    private ConsumerPrivacyProcessingResult _processing = ConsumerPrivacyProcessingResult.FromRecords([]);
    private bool _isPreparing;
    private bool _isDownloading;
    private bool _failureVisible;
    private bool _confirmErasure;
    private bool _isLoadingErasure;
    private bool _isLoadingProcessing;
    private bool _isRequestingErasure;
    private bool _isCancellingErasure;
    private bool _erasureAlertVisible;
    private ConsumerPrivacyErasureOutcome? _lastErasureFailure;

    private string _titleId => $"hx-parties-privacy-title-{_instanceId}";
    private string _exportId => $"hx-parties-privacy-export-{_instanceId}";
    private string _failureId => $"hx-parties-privacy-failure-{_instanceId}";
    private string _processingId => $"hx-parties-privacy-processing-{_instanceId}";
    private string _processingFailureId => $"hx-parties-privacy-processing-failure-{_instanceId}";
    private string _erasureId => $"hx-parties-privacy-erasure-{_instanceId}";
    private string _erasureFailureId => $"hx-parties-privacy-erasure-failure-{_instanceId}";
    private string _erasureConfirmId => $"hx-parties-privacy-erasure-confirm-{_instanceId}";

    private bool CanDownload
        => _download is { Payload.Length: > 0 }
            && !_isPreparing
            && _download.Outcome is ConsumerPrivacyExportOutcome.Ready
                or ConsumerPrivacyExportOutcome.Restricted
                or ConsumerPrivacyExportOutcome.Erased
                or ConsumerPrivacyExportOutcome.Unavailable;

    private string StatusMessage
        => _isPreparing
            ? ConsumerPortalLabels.PrivacyExportPreparing
            : _download?.Outcome switch
            {
                ConsumerPrivacyExportOutcome.Restricted => ConsumerPortalLabels.PrivacyExportRestrictedReady,
                ConsumerPrivacyExportOutcome.Erased => ConsumerPortalLabels.PrivacyExportErasedReady,
                ConsumerPrivacyExportOutcome.Unavailable => ConsumerPortalLabels.PrivacyExportUnavailableReady,
                ConsumerPrivacyExportOutcome.Ready => ConsumerPortalLabels.PrivacyExportReady,
                _ => ConsumerPortalLabels.PrivacyExportIdleStatus,
            };

    private bool _erasureBusy => _isLoadingErasure || _isRequestingErasure || _isCancellingErasure;

    private bool CanRequestErasure
        => !_confirmErasure
            && !_erasureBusy
            && _erasure.Outcome is ConsumerPrivacyErasureOutcome.Ready
                or ConsumerPrivacyErasureOutcome.CancellationAccepted
            && _erasure.State is ConsumerPrivacyErasureState.Active;

    private bool CanCancelErasure
        => !_erasureBusy && _erasure.CanCancel && _erasure.State is ConsumerPrivacyErasureState.ErasurePending;

    private bool ShowDisabledCancel
        => _erasure.State is ConsumerPrivacyErasureState.KeyDestroyed
            or ConsumerPrivacyErasureState.VerificationInProgress
            or ConsumerPrivacyErasureState.Verified;

    private bool ShowErasureStatus
        => _erasureBusy
            || _erasure.Outcome is ConsumerPrivacyErasureOutcome.Pending
                or ConsumerPrivacyErasureOutcome.CancellationAccepted
                or ConsumerPrivacyErasureOutcome.Permanent
            || _erasure.State is ConsumerPrivacyErasureState.ErasurePending
                or ConsumerPrivacyErasureState.KeyDestroyed
                or ConsumerPrivacyErasureState.VerificationInProgress
                or ConsumerPrivacyErasureState.Verified
                or ConsumerPrivacyErasureState.Erased;

    private string ErasureStatusMessage
        => _isLoadingErasure
            ? ConsumerPortalLabels.PrivacyErasureLoadingStatus
            : _isRequestingErasure
                ? ConsumerPortalLabels.PrivacyErasureRequesting
                : _isCancellingErasure
                    ? ConsumerPortalLabels.PrivacyErasureCancelling
                    : _erasure.Outcome is ConsumerPrivacyErasureOutcome.CancellationAccepted
                        ? ConsumerPortalLabels.PrivacyErasureCancelled
                        : _erasure.State switch
                        {
                            ConsumerPrivacyErasureState.ErasurePending => ConsumerPortalLabels.PrivacyErasurePendingCancellable,
                            ConsumerPrivacyErasureState.KeyDestroyed
                                or ConsumerPrivacyErasureState.VerificationInProgress
                                or ConsumerPrivacyErasureState.Verified => ConsumerPortalLabels.PrivacyErasureStarted,
                            ConsumerPrivacyErasureState.Erased => ConsumerPortalLabels.PrivacyErasurePermanent,
                            _ => ConsumerPortalLabels.PrivacyErasureIdleStatus,
                        };

    private string ErasureAlertMessage
        => _lastErasureFailure switch
        {
            ConsumerPrivacyErasureOutcome.Forbidden or ConsumerPrivacyErasureOutcome.AuthenticationRequired => ConsumerPortalLabels.PrivacyErasureForbiddenMessage,
            ConsumerPrivacyErasureOutcome.Unavailable => ConsumerPortalLabels.PrivacyErasureUnavailableMessage,
            ConsumerPrivacyErasureOutcome.Rejected => ConsumerPortalLabels.PrivacyErasureRejectedMessage,
            _ => ConsumerPortalLabels.PrivacyErasureFailureMessage,
        };

    private bool ShowProcessingAlert
        => !_isLoadingProcessing
            && _processing.Outcome is ConsumerPrivacyProcessingOutcome.Forbidden
                or ConsumerPrivacyProcessingOutcome.AuthenticationRequired
                or ConsumerPrivacyProcessingOutcome.Unavailable
                or ConsumerPrivacyProcessingOutcome.Stale
                or ConsumerPrivacyProcessingOutcome.TransientFailure
                or ConsumerPrivacyProcessingOutcome.Erased;

    private string ProcessingStatusMessage
        => _isLoadingProcessing
            ? ConsumerPortalLabels.PrivacyProcessingLoadingStatus
            : _processing.Outcome switch
            {
                ConsumerPrivacyProcessingOutcome.Ready => ConsumerPortalLabels.PrivacyProcessingReadyStatus,
                ConsumerPrivacyProcessingOutcome.Empty => ConsumerPortalLabels.PrivacyProcessingEmptyStatus,
                _ => ConsumerPortalLabels.PrivacyProcessingFailureMessage,
            };

    private string ProcessingAlertMessage
        => _processing.Outcome switch
        {
            ConsumerPrivacyProcessingOutcome.Forbidden or ConsumerPrivacyProcessingOutcome.AuthenticationRequired => ConsumerPortalLabels.PrivacyProcessingForbiddenMessage,
            ConsumerPrivacyProcessingOutcome.Unavailable => ConsumerPortalLabels.PrivacyProcessingUnavailableMessage,
            ConsumerPrivacyProcessingOutcome.Stale => ConsumerPortalLabels.PrivacyProcessingStaleMessage,
            ConsumerPrivacyProcessingOutcome.Erased => ConsumerPortalLabels.PrivacyProcessingErasedMessage,
            _ => ConsumerPortalLabels.PrivacyProcessingFailureMessage,
        };

    protected override async Task OnInitializedAsync()
    {
        _erasureCts = new CancellationTokenSource();
        _processingCts = new CancellationTokenSource();

        Task erasureLoad = LoadErasureStatusAsync(_erasureCts.Token);
        Task processingLoad = LoadProcessingSummaryAsync(_processingCts.Token);

        await Task.WhenAll(erasureLoad, processingLoad).ConfigureAwait(false);
    }

    private async Task LoadErasureStatusAsync(CancellationToken token)
    {
        _isLoadingErasure = true;

        try
        {
            ConsumerPrivacyErasureResult result = await ErasureClient.GetMyErasureStatusAsync(token).ConfigureAwait(false);
            if (!token.IsCancellationRequested)
            {
                ApplyErasureResult(result);
            }
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
        }
        catch
        {
            if (!token.IsCancellationRequested)
            {
                ApplyErasureResult(ConsumerPrivacyErasureResult.Failure(ConsumerPrivacyErasureOutcome.TransientFailure));
            }
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isLoadingErasure = false;
            }
        }
    }

    private async Task LoadProcessingSummaryAsync(CancellationToken token)
    {
        _isLoadingProcessing = true;

        try
        {
            ConsumerPrivacyProcessingResult result = await ProcessingClient.GetMyProcessingSummaryAsync(token).ConfigureAwait(false);
            if (!token.IsCancellationRequested)
            {
                _processing = result;
            }
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
        }
        catch
        {
            if (!token.IsCancellationRequested)
            {
                _processing = ConsumerPrivacyProcessingResult.Failure(ConsumerPrivacyProcessingOutcome.TransientFailure);
            }
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isLoadingProcessing = false;
            }
        }
    }

    private async Task PrepareExportAsync()
    {
        _exportCts?.Cancel();
        _exportCts?.Dispose();
        _exportCts = new CancellationTokenSource();
        CancellationToken token = _exportCts.Token;

        _isPreparing = true;
        _failureVisible = false;

        try
        {
            ConsumerPrivacyExportResult result = await ExportClient.ExportMyDataAsync(token).ConfigureAwait(false);
            if (token.IsCancellationRequested)
            {
                return;
            }

            if (result.Payload.Length == 0
                || result.Outcome is ConsumerPrivacyExportOutcome.TransientFailure
                    or ConsumerPrivacyExportOutcome.Forbidden
                    or ConsumerPrivacyExportOutcome.Failed)
            {
                _failureVisible = true;
                return;
            }

            _download = result;
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
        }
        catch
        {
            if (!token.IsCancellationRequested)
            {
                _failureVisible = true;
            }
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isPreparing = false;
            }
        }
    }

    private async Task DownloadAsync()
    {
        if (!CanDownload || _download is null)
        {
            return;
        }

        _isDownloading = true;
        _failureVisible = false;

        try
        {
            await using var stream = new MemoryStream(_download.Payload, writable: false);
            using var streamReference = new DotNetStreamReference(stream);
            await JsRuntime.InvokeVoidAsync(
                "HexalithPartiesConsumerPortal.downloadJson",
                _download.SafeFileName,
                _download.ContentType,
                streamReference).ConfigureAwait(false);
        }
        catch (JSDisconnectedException)
        {
            _failureVisible = true;
        }
        catch (JSException)
        {
            _failureVisible = true;
        }
        finally
        {
            _isDownloading = false;
        }
    }

    private void BeginErasureConfirmation()
    {
        _erasureAlertVisible = false;
        _confirmErasure = true;
    }

    private void DismissErasureConfirmation() => _confirmErasure = false;

    private async Task RequestErasureAsync()
    {
        _erasureCts?.Cancel();
        _erasureCts?.Dispose();
        _erasureCts = new CancellationTokenSource();
        CancellationToken token = _erasureCts.Token;

        _isRequestingErasure = true;
        _erasureAlertVisible = false;

        try
        {
            ConsumerPrivacyErasureResult result = await ErasureClient.RequestMyErasureAsync(token).ConfigureAwait(false);
            if (!token.IsCancellationRequested)
            {
                _confirmErasure = false;
                ApplyErasureResult(result);
            }
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
        }
        catch
        {
            if (!token.IsCancellationRequested)
            {
                ApplyErasureResult(ConsumerPrivacyErasureResult.Failure(ConsumerPrivacyErasureOutcome.TransientFailure));
            }
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isRequestingErasure = false;
            }
        }
    }

    private async Task CancelErasureAsync()
    {
        _erasureCts?.Cancel();
        _erasureCts?.Dispose();
        _erasureCts = new CancellationTokenSource();
        CancellationToken token = _erasureCts.Token;

        _isCancellingErasure = true;
        _erasureAlertVisible = false;

        try
        {
            ConsumerPrivacyErasureResult result = await ErasureClient.CancelMyErasureAsync(token).ConfigureAwait(false);
            if (!token.IsCancellationRequested)
            {
                ApplyErasureResult(result);
            }
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
        }
        catch
        {
            if (!token.IsCancellationRequested)
            {
                ApplyErasureResult(ConsumerPrivacyErasureResult.Failure(ConsumerPrivacyErasureOutcome.TransientFailure));
            }
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isCancellingErasure = false;
            }
        }
    }

    private void ApplyErasureResult(ConsumerPrivacyErasureResult result)
    {
        _erasure = result;
        _lastErasureFailure = result.Outcome;
        _erasureAlertVisible = result.Outcome is ConsumerPrivacyErasureOutcome.Forbidden
            or ConsumerPrivacyErasureOutcome.AuthenticationRequired
            or ConsumerPrivacyErasureOutcome.Rejected
            or ConsumerPrivacyErasureOutcome.TransientFailure
            or ConsumerPrivacyErasureOutcome.Unavailable;
    }

    private static string SafeProcessingSummary(ConsumerPrivacyProcessingRecord record)
        => string.IsNullOrWhiteSpace(record.Summary)
            ? ConsumerPortalLabels.PrivacyProcessingSummaryFallback
            : record.Summary;

    public void Dispose()
    {
        _exportCts?.Cancel();
        _exportCts?.Dispose();
        _erasureCts?.Cancel();
        _erasureCts?.Dispose();
        _processingCts?.Cancel();
        _processingCts?.Dispose();
    }
}
