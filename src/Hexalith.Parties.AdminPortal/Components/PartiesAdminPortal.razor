    private bool ShouldAutoFocusRow(PartyIndexEntry row)
    {
        if (!string.Equals(_pendingRowFocusPartyId, row.Id, StringComparison.Ordinal))
        {
            return false;
        }

        _pendingRowFocusPartyId = null;
        return true;
    }

    private async Task OnGridKeyDownAsync(KeyboardEventArgs e)
    {
        if (_rows.Count == 0)
        {
            return;
        }

        if (e.Key is "ArrowDown")
        {
            _focusedRowIndex = Math.Min(_focusedRowIndex + 1, _rows.Count - 1);
            await SafeStateHasChangedAsync().ConfigureAwait(false);
            return;
        }

        if (e.Key is "ArrowUp")
        {
            _focusedRowIndex = Math.Max(_focusedRowIndex - 1, 0);
            await SafeStateHasChangedAsync().ConfigureAwait(false);
            return;
        }

        if (e.Key is "Enter")
        {
            await SelectPartyAsync(_rows[_focusedRowIndex].Id).ConfigureAwait(false);
            return;
        }

        if (e.Key.Length == 1 && !e.CtrlKey && !e.AltKey && !e.MetaKey)
        {
            _pendingFocus = FocusTarget.SearchInput;
            await SafeStateHasChangedAsync().ConfigureAwait(false);
        }
    }

    private string RowStatusId(PartyIndexEntry row)
        => $"party-row-state-{_instanceId}-{SafeDomToken(row.Id)}";

    private static string SafeDomToken(string value)
    {
        const uint offsetBasis = 2166136261;
        const uint prime = 16777619;
        uint hash = offsetBasis;
        foreach (char c in value)
        {
            hash ^= c;
            hash *= prime;
        }

        return hash.ToString("x8", CultureInfo.InvariantCulture);
    }

    private string DetailStatus(PartyDetail detail)
    {
        if (detail.IsErased)
        {
            return EffectiveLabels.Erased;
        }

        if (detail.IsRestricted)
        {
            return EffectiveLabels.RestrictedState;
        }

        return detail.IsActive ? EffectiveLabels.Active : EffectiveLabels.Inactive;
    }

    private string PartyStateBadgeClass(bool isActive, bool isRestricted, bool isErased)
    {
        string state = isErased
            ? "erased"
            : isRestricted
                ? "restricted"
                : isActive
                    ? "active"
                    : "inactive";
        return $"hx-parties-admin__badge party-state-badge hx-parties-admin__badge--{state}";
    }

    private RenderFragment RenderFreshness() => builder =>
    {
        string statusClass = _detailMetadata is null || !_detailMetadata.IsDegraded
            ? "data-freshness-indicator--current"
            : "data-freshness-indicator--degraded";
        string message = _detailMetadata?.StaleDataAge is not null
            ? EffectiveLabels.FreshnessStale
            : _detailMetadata?.IsDegraded == true
                ? EffectiveLabels.FreshnessLastKnown
                : EffectiveLabels.FreshnessCurrent;

        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"data-freshness-indicator hx-parties-admin__freshness {statusClass}");
        builder.OpenElement(2, "span");
        builder.AddAttribute(3, "class", "data-freshness-indicator__dot");
        builder.AddAttribute(4, "aria-hidden", "true");
        builder.CloseElement();
        builder.OpenElement(5, "span");
        builder.AddAttribute(6, "role", "status");
        builder.AddAttribute(7, "aria-live", "polite");
        builder.AddContent(8, message);
        builder.CloseElement();
        builder.CloseElement();
    };

