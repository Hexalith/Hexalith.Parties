@page "/admin/parties"
@inject AdminPortalPartyQueryService QueryService
@inject PartiesAdminListCoordinator ListCoordinator
@inject IAdminPortalAuthorizationService AuthorizationService
@inject AdminPortalEventStoreAdminLinks EventStoreLinks
@inject AdminPortalGdprStateCoordinator GdprCoordinator
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IDisposable

<section class="hx-parties-admin" aria-labelledby="@($"hx-parties-admin-title-{_instanceId}")">
    <header class="hx-parties-admin__header">
        <h1 id="@($"hx-parties-admin-title-{_instanceId}")">@EffectiveLabels.Title</h1>
        <p class="hx-parties-admin__status" role="status" aria-live="polite">@StatusText</p>
    </header>

    <div class="hx-parties-admin__toolbar" @onkeydown="OnToolbarKeyDownAsync">
        <FluentTextInput Value="@_filters.Query"
                         ValueChanged="OnQueryChanged"
                         TextInputType="TextInputType.Search"
                         Label="@EffectiveLabels.Search"
                         aria-label="@EffectiveLabels.SearchAriaLabel"
                         Placeholder="@EffectiveLabels.SearchPlaceholder"
                         @ref="_searchInputRef" />
        <FluentSelect TOption="string" TValue="string"
                      Items="@_partyTypeOptions"
                      Value="@_filters.TypeValue"
                      ValueChanged="OnTypeChanged"
                      OptionText="PartyTypeOptionLabel"
                      Label="@EffectiveLabels.PartyType"
                      aria-label="@EffectiveLabels.PartyType"
                      Disabled="@FiltersDisabledInSearchMode" />
        <FluentSelect TOption="string" TValue="string"
                      Items="@_activeStateOptions"
                      Value="@_filters.ActiveValue"
                      ValueChanged="OnActiveChanged"
                      OptionText="ActiveStateOptionLabel"
                      Label="@EffectiveLabels.ActiveState"
                      aria-label="@EffectiveLabels.ActiveState"
                      Disabled="@FiltersDisabledInSearchMode" />
        <FluentButton Appearance="ButtonAppearance.Primary" OnClick="SubmitSearchAsync">@EffectiveLabels.Submit</FluentButton>
        <FluentButton Appearance="ButtonAppearance.Outline" OnClick="ClearFiltersAsync">@EffectiveLabels.Clear</FluentButton>
        @if (RetryAvailable)
        {
            <FluentButton Appearance="ButtonAppearance.Outline" OnClick="RetryAsync">@EffectiveLabels.Retry</FluentButton>
        }
    </div>

    <div class="hx-parties-admin__search-modes" aria-label="@EffectiveLabels.SearchModesRegion">
        <FluentButton Disabled="true">@EffectiveLabels.DisplayNameMode</FluentButton>
        <FluentButton Disabled="@(!IsRichSearchAvailable)">@EffectiveLabels.EmailMode</FluentButton>
        <FluentButton Disabled="@(!IsRichSearchAvailable)">@EffectiveLabels.IdentifierMode</FluentButton>
    </div>

    <div class="hx-parties-admin__layout">
        <div class="hx-parties-admin__list">
            <FluentDataGrid Items="@RowsQuery"
                            GridTemplateColumns="2fr 1fr 1fr 1fr 1fr"
                            DisplayMode="DataGridDisplayMode.Table"
                            aria-label="@EffectiveLabels.PartiesGrid">
                <TemplateColumn Title="@EffectiveLabels.DisplayNameColumn" Context="row">
                    <FluentButton Appearance="ButtonAppearance.Subtle" OnClick="() => SelectPartyAsync(row.Id)">
                        @row.DisplayName
                    </FluentButton>
                </TemplateColumn>
                <TemplateColumn Title="@EffectiveLabels.TypeColumn" Context="row">
                    @EffectiveLabels.PartyTypeLabel(row.Type.ToString())
                </TemplateColumn>
                <TemplateColumn Title="@EffectiveLabels.StateColumn" Context="row">
                    <span class="hx-parties-admin__badge" aria-label="@StatusLabel(row)">
                        @StatusLabel(row)
                    </span>
                </TemplateColumn>
                <TemplateColumn Title="@EffectiveLabels.CreatedColumn" Context="row">
                    @FormatDate(row.CreatedAt)
                </TemplateColumn>
                <TemplateColumn Title="@EffectiveLabels.ModifiedColumn" Context="row">
                    @FormatDate(row.LastModifiedAt)
                </TemplateColumn>
            </FluentDataGrid>

            @if (!_isLoading && _rows.Count == 0)
            {
                <p class="hx-parties-admin__empty">@EmptyText</p>
            }

            <nav class="hx-parties-admin__paging" aria-label="@EffectiveLabels.PagingRegion">
                <FluentButton Disabled="@(_page <= 1 || _isLoading)" OnClick="PreviousPageAsync">@EffectiveLabels.Previous</FluentButton>
                <span>@EffectiveLabels.Page @_page @EffectiveLabels.Of @_totalPages, @_totalCount @EffectiveLabels.TotalCount</span>
                <FluentButton Disabled="@(!_hasNextPage || _isLoading)" OnClick="NextPageAsync">@EffectiveLabels.Next</FluentButton>
            </nav>
        </div>

        <aside class="hx-parties-admin__detail" aria-label="@EffectiveLabels.DetailRegion">
            @if (_isDetailLoading)
            {
                <p role="status" aria-live="polite">@EffectiveLabels.DetailLoading</p>
            }
            else if (_detail is null)
            {
                <p>@DetailEmptyText</p>
            }
            else
            {
                <h2>@_detail.DisplayName</h2>
                @if (_detailMetadata?.StaleDataAge is not null)
                {
                    <p class="hx-parties-admin__status" role="status">@EffectiveLabels.DataAge: @_detailMetadata.StaleDataAge</p>
                }

                <section aria-labelledby="@($"party-summary-heading-{_instanceId}")">
                    <h3 id="@($"party-summary-heading-{_instanceId}")">@EffectiveLabels.Summary</h3>
                    <dl>
                        <dt>@EffectiveLabels.TypeColumn</dt>
                        <dd>@EffectiveLabels.PartyTypeLabel(_detail.Type.ToString())</dd>
                        <dt>@EffectiveLabels.Status</dt>
                        <dd>@DetailStatus(_detail)</dd>
                        <dt>@EffectiveLabels.CreatedColumn</dt>
                        <dd>@FormatDate(_detail.CreatedAt)</dd>
                        <dt>@EffectiveLabels.ModifiedColumn</dt>
                        <dd>@FormatDate(_detail.LastModifiedAt)</dd>
                    </dl>
                </section>

                @if (_detail.PersonDetails is not null)
                {
                    <section aria-labelledby="@($"person-details-heading-{_instanceId}")">
                        <h3 id="@($"person-details-heading-{_instanceId}")">@EffectiveLabels.PersonDetails</h3>
                        <dl>
                            <dt>@EffectiveLabels.FirstName</dt>
                            <dd>@_detail.PersonDetails.FirstName</dd>
                            <dt>@EffectiveLabels.LastName</dt>
                            <dd>@_detail.PersonDetails.LastName</dd>
                        </dl>
                    </section>
                }

                @if (_detail.OrganizationDetails is not null)
                {
                    <section aria-labelledby="@($"organization-details-heading-{_instanceId}")">
                        <h3 id="@($"organization-details-heading-{_instanceId}")">@EffectiveLabels.OrganizationDetails</h3>
                        <dl>
                            <dt>@EffectiveLabels.LegalName</dt>
                            <dd>@_detail.OrganizationDetails.LegalName</dd>
                            <dt>@EffectiveLabels.TradingName</dt>
                            <dd>@_detail.OrganizationDetails.TradingName</dd>
                            <dt>@EffectiveLabels.LegalForm</dt>
                            <dd>@_detail.OrganizationDetails.LegalForm</dd>
                        </dl>
                    </section>
                }

                <section aria-labelledby="@($"contact-channels-heading-{_instanceId}")">
                    <h3 id="@($"contact-channels-heading-{_instanceId}")">@EffectiveLabels.ContactChannels</h3>
                    @if (_detail.ContactChannels.Count == 0)
                    {
                        <p>@EffectiveLabels.NoContactChannels</p>
                    }
                    else
                    {
                        <ul>
                            @foreach (ContactChannel channel in _detail.ContactChannels)
                            {
                                <li>@EffectiveLabels.ContactChannelTypeLabel(channel.Type.ToString()): @channel.Value (@(channel.IsPreferred ? EffectiveLabels.ContactPreferred : EffectiveLabels.ContactStandard))</li>
                            }
                        </ul>
                    }
                </section>

                <section aria-labelledby="@($"identifiers-heading-{_instanceId}")">
                    <h3 id="@($"identifiers-heading-{_instanceId}")">@EffectiveLabels.Identifiers</h3>
                    @if (_detail.Identifiers.Count == 0)
                    {
                        <p>@EffectiveLabels.NoIdentifiers</p>
                    }
                    else
                    {
                        <ul>
                            @foreach (PartyIdentifier identifier in _detail.Identifiers)
                            {
                                <li>@EffectiveLabels.IdentifierTypeLabel(identifier.Type.ToString()): @identifier.Value</li>
                            }
                        </ul>
                    }
                </section>

                <section aria-labelledby="@($"consents-heading-{_instanceId}")">
                    <h3 id="@($"consents-heading-{_instanceId}")">@EffectiveLabels.ConsentRecords</h3>
                    @if (_detail.ConsentRecords.Count == 0)
                    {
                        <p>@EffectiveLabels.NoConsentRecords</p>
                    }
                    else
                    {
                        <ul>
                            @foreach (ConsentRecord consent in _detail.ConsentRecords)
                            {
                                <li>@EffectiveLabels.ConsentPurposeLabel(consent.Purpose.ToString()): @(consent.IsActive ? EffectiveLabels.ConsentActive : EffectiveLabels.ConsentRevoked)</li>
                            }
                        </ul>
                    }
                </section>

                <section aria-labelledby="@($"restrictions-heading-{_instanceId}")">
                    <h3 id="@($"restrictions-heading-{_instanceId}")">@EffectiveLabels.Restrictions</h3>
                    <dl>
                        <dt>@EffectiveLabels.Restricted</dt>
                        <dd>@BooleanText(_detail.IsRestricted)</dd>
                        <dt>@EffectiveLabels.RestrictedAt</dt>
                        <dd>@FormatOptionalDate(_detail.RestrictedAt)</dd>
                        <dt>@EffectiveLabels.Erased</dt>
                        <dd>@BooleanText(_detail.IsErased)</dd>
                        <dt>@EffectiveLabels.ErasedAt</dt>
                        <dd>@FormatOptionalDate(_detail.ErasedAt)</dd>
                    </dl>
                </section>

                <PartyGdprOperationsPanel Party="_detail"
                                          Labels="EffectiveLabels"
                                          TenantContextSignature="_authorizationState.ContextSignature"
                                          RefreshParty="RefreshSelectedPartyAsync" />

                <section aria-labelledby="@($"eventstore-links-heading-{_instanceId}")">
                    <h3 id="@($"eventstore-links-heading-{_instanceId}")">@EffectiveLabels.EventStoreLinks</h3>
                    @if (EventStoreLinks.BuildStreamLink(_detail.Id) is { } streamLink)
                    {
                        <a href="@streamLink" target="_blank" rel="noopener noreferrer">@EffectiveLabels.OpenEventStoreStream</a>
                    }
                    else
                    {
                        <FluentButton Appearance="ButtonAppearance.Outline" Disabled="true">
                            @EffectiveLabels.EventStoreAdminUnavailable
                        </FluentButton>
                    }
                </section>

                @* P-pass-2 D3.1: scoped party id is intentionally not displayed as a user-facing
                    label per Story 10.1 task line 60 ("do not display tenant:domain:aggregateId
                    scoped ids as user-facing labels"). *@
                <section aria-labelledby="@($"system-metadata-heading-{_instanceId}")">
                    <h3 id="@($"system-metadata-heading-{_instanceId}")">@EffectiveLabels.SystemMetadata</h3>
                    <dl>
                        <dt>@EffectiveLabels.SortName</dt>
                        <dd>@_detail.SortName</dd>
                    </dl>
                </section>

                <section aria-labelledby="@($"name-history-heading-{_instanceId}")">
                    <h3 id="@($"name-history-heading-{_instanceId}")">@EffectiveLabels.NameHistory</h3>
                    @if (_detail.NameHistory.Count == 0)
                    {
                        <p>@EffectiveLabels.NoNameHistory</p>
                    }
                    else
                    {
                        <ul>
                            @foreach (NameHistoryEntry entry in _detail.NameHistory)
                            {
                                <li>
                                    @entry.DisplayName
                                    <dl>
                                        <dt>@EffectiveLabels.SortName</dt>
                                        <dd>@entry.SortName</dd>
                                        <dt>@EffectiveLabels.ChangedAt</dt>
                                        <dd>@FormatDate(entry.ChangedAt)</dd>
                                        @if (!string.IsNullOrWhiteSpace(entry.TriggeredBy))
                                        {
                                            <dt>@EffectiveLabels.TriggeredBy</dt>
                                            <dd>@entry.TriggeredBy</dd>
                                        }
                                    </dl>
                                </li>
                            }
                        </ul>
                    }
                </section>
            }
        </aside>
    </div>
</section>

@code {
    private readonly PortalFilters _filters = new();
    private readonly List<PartyIndexEntry> _rows = [];
    private readonly string[] _partyTypeOptions = ["", "Person", "Organization"];
    private readonly string[] _activeStateOptions = ["", "true", "false"];
    private readonly string _instanceId = Guid.NewGuid().ToString("N").Substring(0, 8);
    private readonly CancellationTokenSource _lifetimeCts = new();
    private long _authContextClaim;
    private CancellationTokenSource? _listCts;
    private CancellationTokenSource? _detailCts;
    private PartyDetail? _detail;
    private AdminPortalQueryMetadata? _detailMetadata;
    private string? _selectedPartyId;
    private string? _previousContextSignature;
    private AdminPortalAuthorizationState _authorizationState = AdminPortalAuthorizationState.Unauthenticated;
    private AdminPortalRichSearchCapability _richSearchCapability = AdminPortalRichSearchCapability.LocalOnly();
    private StatusKind _statusKind = StatusKind.Loading;
    private DetailEmptyKind _detailEmptyKind = DetailEmptyKind.SelectParty;
    private string? _validationDetail;
    private int _page = 1;
    private int _totalPages;
    private int _totalCount;
    private bool _hasNextPage;
    private bool _isLoading;
    private bool _isDetailLoading;
    private long _listVersion;
    private long _detailVersion;
    private int _disposed;
    private AdminPortalQueryFailureKind? _lastFailure;
    private string? _richSearchCapabilityContextSignature;
    private FocusTarget _pendingFocus = FocusTarget.None;
    private FluentTextInput? _searchInputRef;

    [Parameter]
    public string? ContextKey { get; set; }

    [Parameter]
    public int PageSize { get; set; } = AdminPortalQueryBounds.DefaultPageSize;

    [Parameter]
    public AdminPortalLabels? Labels { get; set; }

    private AdminPortalLabels EffectiveLabels => Labels ?? new AdminPortalLabels();

    private bool IsRichSearchAvailable => _richSearchCapability.IsAvailable;

    private bool FiltersDisabledInSearchMode => !string.IsNullOrWhiteSpace(_filters.Query);

    private IQueryable<PartyIndexEntry> RowsQuery => _rows.AsQueryable();

    private bool RetryAvailable
        => _lastFailure is AdminPortalQueryFailureKind.TransientFailure
            or AdminPortalQueryFailureKind.Unknown;

    private string StatusText => _statusKind switch
    {
        StatusKind.Loading => EffectiveLabels.Loading,
        StatusKind.Loaded => EffectiveLabels.Loaded,
        StatusKind.DisplayNameOnly => EffectiveLabels.DisplayNameOnly,
        StatusKind.RichSearchProbeDegraded => EffectiveLabels.RichSearchProbeDegraded,
        StatusKind.Degraded => EffectiveLabels.Degraded,
        StatusKind.SignInRequired => EffectiveLabels.SignInRequired,
        StatusKind.TenantUnavailable => EffectiveLabels.TenantUnavailable,
        StatusKind.AdminRequired => EffectiveLabels.AdminRequired,
        StatusKind.Forbidden => EffectiveLabels.AdminRequired,
        StatusKind.TransientFailure => EffectiveLabels.TransientFailure,
        StatusKind.NoData => EffectiveLabels.NoData,
        StatusKind.LoadFailure => EffectiveLabels.LoadFailure,
        StatusKind.Validation => string.IsNullOrWhiteSpace(_validationDetail)
            ? EffectiveLabels.LoadFailure
            : $"{EffectiveLabels.ValidationProblemPrefix}: {_validationDetail}",
        _ => EffectiveLabels.Loading,
    };

    private string EmptyText => _statusKind switch
    {
        StatusKind.SignInRequired => EffectiveLabels.SignInToBrowse,
        StatusKind.TenantUnavailable => EffectiveLabels.SelectTenant,
        StatusKind.AdminRequired => EffectiveLabels.AccessDenied,
        StatusKind.Forbidden => EffectiveLabels.AccessDenied,
        _ => string.IsNullOrWhiteSpace(_filters.Query)
            ? EffectiveLabels.NoParties
            : EffectiveLabels.NoMatches,
    };

    private string DetailEmptyText => _detailEmptyKind switch
    {
        DetailEmptyKind.SignInRequired => EffectiveLabels.SignInRequired,
        DetailEmptyKind.TenantUnavailable => EffectiveLabels.TenantUnavailable,
        DetailEmptyKind.AccessDenied => EffectiveLabels.AccessDenied,
        DetailEmptyKind.DetailUnavailable => EffectiveLabels.DetailUnavailable,
        DetailEmptyKind.DetailErased => EffectiveLabels.DetailErased,
        DetailEmptyKind.TransientFailure => EffectiveLabels.TransientFailure,
        DetailEmptyKind.DetailLoadFailure => EffectiveLabels.DetailLoadFailure,
        _ => EffectiveLabels.SelectParty,
    };

    protected override void OnInitialized()
    {
        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
    }

    protected override Task OnParametersSetAsync() => ApplyAuthorizationContextAsync();

    private async Task ApplyAuthorizationContextAsync()
    {
        if (Volatile.Read(ref _disposed) != 0)
        {
            return;
        }

        // Each invocation claims a monotonic version. A later caller (e.g., AuthenticationStateChanged
        // firing during OnParametersSetAsync) supersedes the earlier one: when the earlier
        // caller resumes after its await, it sees a newer claim and exits without writing
        // back state. This prevents two interleaved callers from both painting state across
        // a tenant switch (cross-tenant leak) without holding a lock that would deadlock the
        // cancellation flow when LoadPageAsync is awaiting an in-flight HTTP call.
        long claim = Interlocked.Increment(ref _authContextClaim);

        AdminPortalAuthorizationState authorizationState = await AuthorizationService
            .GetAuthorizationStateAsync(_lifetimeCts.Token)
            .ConfigureAwait(false);

        if (claim != Volatile.Read(ref _authContextClaim))
        {
            return;
        }

        string signature = string.Join('|',
            ContextKey ?? "<null>",
            authorizationState.ContextSignature,
            PageSize);
        if (string.Equals(_previousContextSignature, signature, StringComparison.Ordinal))
        {
            return;
        }

        _previousContextSignature = signature;
        _authorizationState = authorizationState;
        if (!string.Equals(_richSearchCapabilityContextSignature, authorizationState.ContextSignature, StringComparison.Ordinal))
        {
            _richSearchCapability = AdminPortalRichSearchCapability.LocalOnly();
            _richSearchCapabilityContextSignature = null;
        }

        ResetVisibleState();

        if (!_authorizationState.IsAuthenticated)
        {
            GdprCoordinator.ResetForSignOut();
            _statusKind = StatusKind.SignInRequired;
            _detailEmptyKind = DetailEmptyKind.SignInRequired;
            ListCoordinator.Transition(AdminPortalListState.MissingToken);
            return;
        }

        if (!_authorizationState.HasTenantContext)
        {
            GdprCoordinator.ResetForTenantSwitch();
            _statusKind = StatusKind.TenantUnavailable;
            _detailEmptyKind = DetailEmptyKind.TenantUnavailable;
            ListCoordinator.Transition(AdminPortalListState.MissingTenant);
            return;
        }

        if (!_authorizationState.IsAdmin)
        {
            GdprCoordinator.ResetForAuthorizationFailure();
            _statusKind = StatusKind.AdminRequired;
            _detailEmptyKind = DetailEmptyKind.AccessDenied;
            ListCoordinator.Transition(AdminPortalListState.Forbidden);
            return;
        }

        await EnsureRichSearchCapabilityAsync(authorizationState.ContextSignature).ConfigureAwait(false);

        if (claim != Volatile.Read(ref _authContextClaim))
        {
            return;
        }

        await LoadPageAsync().ConfigureAwait(false);
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                await ApplyAuthorizationContextAsync().ConfigureAwait(false);
                await SafeStateHasChangedAsync().ConfigureAwait(false);
            }
            catch (OperationCanceledException)
            {
                // Component disposed while applying — drop silently.
            }
            catch (Exception ex)
            {
                // Surface auth-state errors as the failure UI rather than dropping silently
                // through a discarded fire-and-forget Task.
                _statusKind = StatusKind.LoadFailure;
                _validationDetail = ex.Message;
                _lastFailure = AdminPortalQueryFailureKind.Unknown;
                ListCoordinator.Transition(AdminPortalListState.TransientFailure);
                await SafeStateHasChangedAsync().ConfigureAwait(false);
            }
        });
    }

    private async Task OnToolbarKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitSearchAsync().ConfigureAwait(false);
        }
    }

    private async Task SubmitSearchAsync()
    {
        _page = 1;
        _pendingFocus = FocusTarget.SearchInput;
        await LoadPageAsync().ConfigureAwait(false);
    }

    private void OnQueryChanged(string value) => _filters.Query = value;

    private void OnTypeChanged(string value) => _filters.TypeValue = value;

    private void OnActiveChanged(string value) => _filters.ActiveValue = value;

    private async Task ClearFiltersAsync()
    {
        _filters.Query = string.Empty;
        _filters.TypeValue = string.Empty;
        _filters.ActiveValue = string.Empty;
        _page = 1;
        _pendingFocus = FocusTarget.SearchInput;
        await LoadPageAsync().ConfigureAwait(false);
    }

    private async Task PreviousPageAsync()
    {
        if (_page > 1)
        {
            _page--;
            await LoadPageAsync().ConfigureAwait(false);
        }
    }

    private async Task NextPageAsync()
    {
        if (_hasNextPage)
        {
            _page++;
            await LoadPageAsync().ConfigureAwait(false);
        }
    }

    private Task RetryAsync() => LoadPageAsync();

    private async Task LoadPageAsync()
    {
        if (Volatile.Read(ref _disposed) != 0)
        {
            return;
        }

        long version = SwapListCts(out CancellationToken token);
        _isLoading = true;
        _statusKind = StatusKind.Loading;
        ListCoordinator.Transition(AdminPortalListState.Loading);
        _validationDetail = null;
        _rows.Clear();
        _detail = null;
        _selectedPartyId = null;
        _detailMetadata = null;
        _detailEmptyKind = DetailEmptyKind.SelectParty;
        _lastFailure = null;

        try
        {
            if (string.IsNullOrWhiteSpace(_filters.Query))
            {
                AdminPortalQueryResult<PagedResult<PartyIndexEntry>> result = await QueryService.ApiClient
                    .ListPartiesAsync(CreateListRequest(), token)
                    .ConfigureAwait(false);
                await ApplyRowsAsync(result.Payload, result.Metadata, version).ConfigureAwait(false);
            }
            else
            {
                AdminPortalQueryResult<PagedResult<PartySearchResult>> result = await QueryService.ApiClient
                    .SearchPartiesAsync(CreateSearchRequest(), token)
                    .ConfigureAwait(false);
                PagedResult<PartyIndexEntry> page = new()
                {
                    Items = [.. result.Payload.Items.Where(static x => x.Party is not null).Select(static x => x.Party!)],
                    Page = result.Payload.Page,
                    PageSize = result.Payload.PageSize,
                    TotalCount = result.Payload.TotalCount,
                    TotalPages = result.Payload.TotalPages,
                };
                await ApplyRowsAsync(page, result.Metadata, version).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (AdminPortalQueryException ex)
        {
            if (version == _listVersion)
            {
                ApplyFailure(ex);
            }
        }
        finally
        {
            if (version == _listVersion)
            {
                _isLoading = false;
            }

            await SafeStateHasChangedAsync().ConfigureAwait(false);
        }
    }

    private async Task ApplyRowsAsync(PagedResult<PartyIndexEntry> page, AdminPortalQueryMetadata metadata, long version)
    {
        if (version != _listVersion)
        {
            return;
        }

        _rows.Clear();
        // Backend already filters erased parties from list/search; trust server counts.
        // No client-side IsErased filter — would otherwise leak an erased-count signal via
        // total/displayed mismatch (P8).
        _rows.AddRange(page.Items);
        _totalPages = page.TotalPages;
        _totalCount = page.TotalCount;

        // Canonicalize _page from the server response so subsequent Previous/Next navigate
        // from what the server actually served. When the server returns Page == 0 (e.g.,
        // empty result with TotalPages > 0 because the client overflowed past the last
        // available page), pin _page to TotalPages or 1 so the user is not stranded on a
        // page that does not exist.
        _page = page.Page > 0
            ? page.Page
            : page.TotalPages > 0 ? page.TotalPages : 1;

        _hasNextPage = page.TotalPages > _page;
        bool degraded = _richSearchCapability.IsDegraded
            || metadata.IsLocalOnlySearch
            || metadata.IsDegraded;
        _statusKind = _richSearchCapability.IsDegraded
            ? StatusKind.RichSearchProbeDegraded
            : metadata.IsLocalOnlySearch
            ? StatusKind.DisplayNameOnly
            : metadata.IsDegraded
                ? StatusKind.Degraded
                : StatusKind.Loaded;
        ListCoordinator.Transition(_rows.Count == 0
            ? AdminPortalListState.ReadyEmpty
            : degraded
                ? AdminPortalListState.DegradedSearch
                : AdminPortalListState.ReadyHasResults);
        await SafeStateHasChangedAsync().ConfigureAwait(false);
    }

    private async Task EnsureRichSearchCapabilityAsync(string contextSignature)
    {
        if (string.Equals(_richSearchCapabilityContextSignature, contextSignature, StringComparison.Ordinal))
        {
            return;
        }

        // Use the per-instance lifetime token so an in-flight probe is canceled on disposal
        // rather than completing against a torn-down component.
        _richSearchCapability = await QueryService.ApiClient
            .GetRichSearchCapabilityAsync(_lifetimeCts.Token)
            .ConfigureAwait(false);
        _richSearchCapabilityContextSignature = contextSignature;
    }

    private async Task SelectPartyAsync(string partyId)
    {
        if (Volatile.Read(ref _disposed) != 0)
        {
            return;
        }

        _selectedPartyId = partyId;
        long version = SwapDetailCts(out CancellationToken token);
        _isDetailLoading = true;
        await SafeStateHasChangedAsync().ConfigureAwait(false);

        try
        {
            AdminPortalQueryResult<PartyDetail> result = await QueryService.ApiClient
                .GetPartyAsync(partyId, token)
                .ConfigureAwait(false);
            if (version == _detailVersion)
            {
                if (result.Payload.IsErased)
                {
                    // P30: align 200-with-erased path to the 410 path — remove the row from
                    // the visible list so the user cannot click it again.
                    _detail = null;
                    _detailMetadata = result.Metadata;
                    _detailEmptyKind = DetailEmptyKind.DetailErased;
                    GdprCoordinator.ResetForErasedTerminalState();
                    _rows.RemoveAll(row => string.Equals(row.Id, partyId, StringComparison.Ordinal));
                }
                else
                {
                    _detail = NormalizeDetail(result.Payload);
                    _detailMetadata = result.Metadata;
                    _detailEmptyKind = DetailEmptyKind.SelectParty;
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (AdminPortalQueryException ex)
        {
            if (version == _detailVersion)
            {
                _detail = null;
                _detailMetadata = null;
                _detailEmptyKind = ex.Kind switch
                {
                    AdminPortalQueryFailureKind.AuthenticationRequired => DetailEmptyKind.SignInRequired,
                    AdminPortalQueryFailureKind.TenantRequired => DetailEmptyKind.TenantUnavailable,
                    AdminPortalQueryFailureKind.Forbidden => DetailEmptyKind.AccessDenied,
                    AdminPortalQueryFailureKind.NotFound => DetailEmptyKind.DetailUnavailable,
                    AdminPortalQueryFailureKind.Gone => DetailEmptyKind.DetailErased,
                    AdminPortalQueryFailureKind.TransientFailure => DetailEmptyKind.TransientFailure,
                    _ => DetailEmptyKind.DetailLoadFailure,
                };

                if (ex.Kind is AdminPortalQueryFailureKind.Gone or AdminPortalQueryFailureKind.NotFound)
                {
                    _rows.RemoveAll(row => string.Equals(row.Id, partyId, StringComparison.Ordinal));
                }

                if (ex.Kind is AdminPortalQueryFailureKind.Gone)
                {
                    GdprCoordinator.ResetForErasedTerminalState();
                }
                else if (ex.Kind is AdminPortalQueryFailureKind.AuthenticationRequired)
                {
                    GdprCoordinator.ResetForSignOut();
                }
                else if (ex.Kind is AdminPortalQueryFailureKind.TenantRequired)
                {
                    GdprCoordinator.ResetForTenantSwitch();
                }
                else if (ex.Kind is AdminPortalQueryFailureKind.Forbidden)
                {
                    GdprCoordinator.ResetForAuthorizationFailure();
                }
            }
        }
        finally
        {
            if (version == _detailVersion)
            {
                _isDetailLoading = false;
            }

            await SafeStateHasChangedAsync().ConfigureAwait(false);
        }
    }

    private Task RefreshSelectedPartyAsync()
        => string.IsNullOrWhiteSpace(_selectedPartyId)
            ? Task.CompletedTask
            : SelectPartyAsync(_selectedPartyId);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Volatile.Read(ref _disposed) != 0)
        {
            return;
        }

        FocusTarget pending = _pendingFocus;
        if (pending == FocusTarget.None)
        {
            return;
        }

        _pendingFocus = FocusTarget.None;
        try
        {
            switch (pending)
            {
                case FocusTarget.SearchInput:
                    if (_searchInputRef?.Element is { } searchElement)
                    {
                        await searchElement.FocusAsync().ConfigureAwait(false);
                    }

                    break;
                case FocusTarget.RetryButton:
                    break;
            }
        }
        catch (ObjectDisposedException)
        {
            // Component disposed between render and focus — focus is best-effort.
        }
        catch (InvalidOperationException)
        {
            // Element ref not yet rendered (e.g., retry button not visible) — drop silently.
        }
        catch (Microsoft.JSInterop.JSException)
        {
            // JS interop failure (e.g., disconnected circuit) — focus is best-effort.
        }
    }

    private AdminPortalListRequest CreateListRequest()
        => new(
            AdminPortalQueryBounds.BoundPage(_page),
            AdminPortalQueryBounds.BoundPageSize(PageSize),
            _filters.Type,
            _filters.Active);

    private AdminPortalSearchRequest CreateSearchRequest()
        => new(
            _filters.Query,
            AdminPortalQueryBounds.BoundPage(_page),
            AdminPortalQueryBounds.BoundPageSize(PageSize),
            // Filter values are intentionally not forwarded to the rich-search query contract yet.
            // UI disables the filter selects in search mode (D2.1).
            null,
            null);

    private void ResetVisibleState()
    {
        CancelInFlight();
        // Bump both versions so any in-flight list/detail tasks that resume after this reset
        // see a stale version and short-circuit, preventing cross-tenant data being painted
        // back into _rows/_detail after a tenant switch.
        Interlocked.Increment(ref _listVersion);
        Interlocked.Increment(ref _detailVersion);
        // Cancel the per-circuit scope token and reset the list coordinator so any FrontComposer
        // observer holding a previous-tenant token sees cancellation before the new tenant's
        // load fires (AC4 — wires the previously dead scaffolding into the live lifecycle).
        QueryService.ResetForTenantSwitch();
        ListCoordinator.ResetForTenantSwitch();
        GdprCoordinator.ResetForTenantSwitch();
        _rows.Clear();
        _detail = null;
        _detailMetadata = null;
        _hasNextPage = false;
        _totalPages = 0;
        _totalCount = 0;
        _isLoading = false;
        _isDetailLoading = false;
        _page = 1;
        _statusKind = StatusKind.Loading;
        _detailEmptyKind = DetailEmptyKind.SelectParty;
        _validationDetail = null;
        _lastFailure = null;
    }

    private static PartyDetail NormalizeDetail(PartyDetail detail)
        => detail with
        {
            // System.Text.Json overwrites the contract's `[]` defaults with `null` if a
            // backend response omits/nulls the property, which would NRE the render of
            // .Count and the foreach. Normalize to empty lists at the assignment site.
            ContactChannels = detail.ContactChannels ?? [],
            Identifiers = detail.Identifiers ?? [],
            ConsentRecords = detail.ConsentRecords ?? [],
            NameHistory = detail.NameHistory ?? [],
        };

    private void ApplyFailure(AdminPortalQueryException ex)
    {
        _rows.Clear();
        _detail = null;
        _detailMetadata = null;
        _hasNextPage = false;
        _totalPages = 0;
        _totalCount = 0;
        _lastFailure = ex.Kind;
        if (ex.Kind is AdminPortalQueryFailureKind.AuthenticationRequired)
        {
            GdprCoordinator.ResetForSignOut();
        }
        else if (ex.Kind is AdminPortalQueryFailureKind.TenantRequired)
        {
            GdprCoordinator.ResetForTenantSwitch();
        }
        else if (ex.Kind is AdminPortalQueryFailureKind.Forbidden)
        {
            GdprCoordinator.ResetForAuthorizationFailure();
        }
        else if (ex.Kind is AdminPortalQueryFailureKind.Gone)
        {
            GdprCoordinator.ResetForErasedTerminalState();
        }
        _validationDetail = ex.Kind == AdminPortalQueryFailureKind.Validation
            ? ex.ValidationDetail
            : null;
        _statusKind = ex.Kind switch
        {
            AdminPortalQueryFailureKind.AuthenticationRequired => StatusKind.SignInRequired,
            AdminPortalQueryFailureKind.TenantRequired => StatusKind.TenantUnavailable,
            AdminPortalQueryFailureKind.Forbidden => StatusKind.Forbidden,
            AdminPortalQueryFailureKind.TransientFailure => StatusKind.TransientFailure,
            AdminPortalQueryFailureKind.NotFound => StatusKind.NoData,
            AdminPortalQueryFailureKind.Gone => StatusKind.NoData,
            AdminPortalQueryFailureKind.Validation => StatusKind.Validation,
            _ => StatusKind.LoadFailure,
        };
        _detailEmptyKind = ex.Kind switch
        {
            AdminPortalQueryFailureKind.AuthenticationRequired => DetailEmptyKind.SignInRequired,
            AdminPortalQueryFailureKind.TenantRequired => DetailEmptyKind.TenantUnavailable,
            AdminPortalQueryFailureKind.Forbidden => DetailEmptyKind.AccessDenied,
            _ => DetailEmptyKind.SelectParty,
        };
        ListCoordinator.Transition(ex.Kind switch
        {
            AdminPortalQueryFailureKind.AuthenticationRequired => AdminPortalListState.MissingToken,
            AdminPortalQueryFailureKind.TenantRequired => AdminPortalListState.MissingTenant,
            AdminPortalQueryFailureKind.Forbidden => AdminPortalListState.Forbidden,
            AdminPortalQueryFailureKind.NotFound => AdminPortalListState.NotFound,
            AdminPortalQueryFailureKind.Gone => AdminPortalListState.Gone,
            // Validation/Unknown share the transient bucket on the coordinator surface;
            // the component still distinguishes them via _statusKind for screen text.
            _ => AdminPortalListState.TransientFailure,
        });

        if (RetryAvailable)
        {
            _pendingFocus = FocusTarget.RetryButton;
        }
    }

    private long SwapListCts(out CancellationToken token)
    {
        long version = Interlocked.Increment(ref _listVersion);
        var newCts = new CancellationTokenSource();
        CancellationTokenSource? old = Interlocked.Exchange(ref _listCts, newCts);
        SafeCancel(old);
        token = newCts.Token;
        return version;
    }

    private long SwapDetailCts(out CancellationToken token)
    {
        long version = Interlocked.Increment(ref _detailVersion);
        var newCts = new CancellationTokenSource();
        CancellationTokenSource? old = Interlocked.Exchange(ref _detailCts, newCts);
        SafeCancel(old);
        token = newCts.Token;
        return version;
    }

    private void CancelInFlight()
    {
        SafeCancel(Interlocked.Exchange(ref _listCts, null));
        SafeCancel(Interlocked.Exchange(ref _detailCts, null));
    }

    private static void SafeCancel(CancellationTokenSource? cts)
    {
        if (cts is null)
        {
            return;
        }

        try
        {
            cts.Cancel();
        }
        catch (ObjectDisposedException)
        {
        }
        finally
        {
            cts.Dispose();
        }
    }

    private async Task SafeStateHasChangedAsync()
    {
        if (Volatile.Read(ref _disposed) != 0)
        {
            return;
        }

        try
        {
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private string StatusLabel(PartyIndexEntry row)
    {
        // PartyIndexEntry does not carry IsRestricted (the index projection omits it). The
        // detail panel surfaces the full state matrix including Restricted via DetailStatus
        // — list/detail discrepancy on Restricted state is by design at the contract layer.
        if (row.IsErased)
        {
            return EffectiveLabels.Erased;
        }

        return row.IsActive ? EffectiveLabels.Active : EffectiveLabels.Inactive;
    }

    private string DetailStatus(PartyDetail detail)
    {
        if (detail.IsErased)
        {
            return EffectiveLabels.Erased;
        }

        if (detail.IsRestricted)
        {
            return detail.IsActive
                ? $"{EffectiveLabels.Active}, {EffectiveLabels.Restricted}"
                : $"{EffectiveLabels.Inactive}, {EffectiveLabels.Restricted}";
        }

        return detail.IsActive ? EffectiveLabels.Active : EffectiveLabels.Inactive;
    }

    private string BooleanText(bool value)
        => value ? EffectiveLabels.Yes : EffectiveLabels.No;

    private string FormatOptionalDate(DateTimeOffset? date)
        => date is null ? EffectiveLabels.MissingDate : FormatDate(date.Value);

    private string FormatDate(DateTimeOffset date)
        => date == default
            ? EffectiveLabels.MissingDate
            : date.ToString("g", System.Globalization.CultureInfo.CurrentCulture);

    private string PartyTypeOptionLabel(string value) => value switch
    {
        "" => EffectiveLabels.AllTypes,
        "Person" => EffectiveLabels.PersonOption,
        "Organization" => EffectiveLabels.OrganizationOption,
        _ => value,
    };

    private string ActiveStateOptionLabel(string value) => value switch
    {
        "" => EffectiveLabels.AllStates,
        "true" => EffectiveLabels.Active,
        "false" => EffectiveLabels.Inactive,
        _ => value,
    };

    public void Dispose()
    {
        if (Interlocked.Exchange(ref _disposed, 1) != 0)
        {
            return;
        }

        AuthenticationStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        CancelInFlight();
        try
        {
            _lifetimeCts.Cancel();
        }
        catch (ObjectDisposedException)
        {
        }

        _lifetimeCts.Dispose();
    }

    private enum StatusKind
    {
        Loading,
        Loaded,
        DisplayNameOnly,
        RichSearchProbeDegraded,
        Degraded,
        SignInRequired,
        TenantUnavailable,
        AdminRequired,
        Forbidden,
        TransientFailure,
        NoData,
        LoadFailure,
        Validation,
    }

    private enum DetailEmptyKind
    {
        SelectParty,
        SignInRequired,
        TenantUnavailable,
        AccessDenied,
        DetailUnavailable,
        DetailErased,
        TransientFailure,
        DetailLoadFailure,
    }

    private enum FocusTarget
    {
        None,
        SearchInput,
        RetryButton,
    }

    private sealed class PortalFilters
    {
        public string Query { get; set; } = string.Empty;

        public string TypeValue { get; set; } = string.Empty;

        public string ActiveValue { get; set; } = string.Empty;

        public PartyType? Type
        {
            get
            {
                string trimmed = TypeValue?.Trim() ?? string.Empty;
                return Enum.TryParse(trimmed, ignoreCase: false, out PartyType parsed)
                    && parsed is PartyType.Person or PartyType.Organization
                    && !int.TryParse(trimmed, out _)
                    ? parsed
                    : null;
            }
        }

        public bool? Active
            => bool.TryParse(ActiveValue?.Trim(), out bool parsed) ? parsed : null;
    }
}
