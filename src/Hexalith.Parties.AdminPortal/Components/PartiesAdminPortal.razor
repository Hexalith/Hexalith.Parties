    private sealed class PortalFilters
    {
        public string Query { get; set; } = string.Empty;

        public string TypeValue { get; set; } = string.Empty;

        public string ActiveValue { get; set; } = string.Empty;

        public string CreatedAfterValue { get; set; } = string.Empty;

        public string CreatedBeforeValue { get; set; } = string.Empty;

        public string ModifiedAfterValue { get; set; } = string.Empty;

        public string ModifiedBeforeValue { get; set; } = string.Empty;

        public PartyType? Type
        {
            get
            {
                string trimmed = TypeValue?.Trim() ?? string.Empty;
                return Enum.TryParse(trimmed, ignoreCase: false, out PartyType parsed)
                    && parsed is PartyType.Person or PartyType.Organization
                    && !int.TryParse(trimmed, out _)
                    ? parsed
                    : null;
            }
        }

        public bool? Active
            => bool.TryParse(ActiveValue?.Trim(), out bool parsed) ? parsed : null;

        public bool TryValidateDateFilters(
            AdminPortalLabels labels,
            out DateTimeOffset? createdAfter,
            out DateTimeOffset? createdBefore,
            out DateTimeOffset? modifiedAfter,
            out DateTimeOffset? modifiedBefore,
            out string? validationDetail)
        {
            createdAfter = null;
            createdBefore = null;
            modifiedAfter = null;
            modifiedBefore = null;
            validationDetail = null;

            if (!TryParseDate(CreatedAfterValue, startOfDay: true, out createdAfter)
                || !TryParseDate(CreatedBeforeValue, startOfDay: false, out createdBefore)
                || !TryParseDate(ModifiedAfterValue, startOfDay: true, out modifiedAfter)
                || !TryParseDate(ModifiedBeforeValue, startOfDay: false, out modifiedBefore))
            {
                validationDetail = labels.DateFilterInvalid;
                return false;
            }

            if (createdAfter is not null && createdBefore is not null && createdAfter > createdBefore)
            {
                validationDetail = labels.CreatedDateRangeInvalid;
                return false;
            }

            if (modifiedAfter is not null && modifiedBefore is not null && modifiedAfter > modifiedBefore)
            {
                validationDetail = labels.ModifiedDateRangeInvalid;
                return false;
            }

            return true;
        }

        private static bool TryParseDate(string? value, bool startOfDay, out DateTimeOffset? parsed)
        {
            string trimmed = value?.Trim() ?? string.Empty;
            if (string.IsNullOrEmpty(trimmed))
            {
                parsed = null;
                return true;
            }

            if (!DateOnly.TryParseExact(
                    trimmed,
                    "yyyy-MM-dd",
                    CultureInfo.InvariantCulture,
                    DateTimeStyles.None,
                    out DateOnly date))
            {
                parsed = null;
                return false;
            }

            TimeOnly time = startOfDay ? TimeOnly.MinValue : TimeOnly.MaxValue;
            parsed = new DateTimeOffset(date.ToDateTime(time), TimeSpan.Zero);
            return true;
        }
    }
