@implements IDisposable
@inject AdminPortalPartyQueryService QueryService
@inject AdminPortalEventStoreAdminLinks EventStoreLinks
@inject AdminPortalGdprStateCoordinator GdprCoordinator
@inject IJSRuntime JsRuntime

<section aria-labelledby="@($"gdpr-operations-heading-{_instanceId}")">
    <h3 id="@($"gdpr-operations-heading-{_instanceId}")" tabindex="-1" @ref="_operationsHeading">@Labels.GdprOperations</h3>
    <p role="status" aria-live="polite">@OperationMessage</p>

    <DpoOperationalSummaryPanel Party="Party"
                                Labels="Labels"
                                InstanceId="@_instanceId"
                                IsErasurePending="@IsErasurePending"
                                ProcessingRecordCount="@_processingRecords.Count" />

    <section aria-labelledby="@($"erasure-actions-heading-{_instanceId}")">
        <h4 id="@($"erasure-actions-heading-{_instanceId}")">@Labels.RequestErasure</h4>
        @if (_confirmErasure)
        {
            <p>@Labels.GdprErasureWarning</p>
            <FluentButton Appearance="ButtonAppearance.Primary"
                          Disabled="@_isBusy"
                          OnClick="ConfirmErasureAsync">
                @Labels.GdprConfirmErasure
            </FluentButton>
            <FluentButton Appearance="ButtonAppearance.Outline"
                          Disabled="@_isBusy"
                          OnClick="CancelErasure">
                @Labels.GdprCancel
            </FluentButton>
        }
        else
        {
            <FluentButton Appearance="ButtonAppearance.Outline"
                          Disabled="@(!CanRequestErasure)"
                          OnClick="BeginErasureConfirmation">
                @Labels.RequestErasure
            </FluentButton>
        }
        <FluentButton Appearance="ButtonAppearance.Outline"
                      Disabled="@_isBusy"
                      OnClick="RefreshErasureStatusAsync">
            @Labels.GdprRefreshStatus
        </FluentButton>
        @if (CanRetryVerification)
        {
            <FluentButton Appearance="ButtonAppearance.Outline"
                          Disabled="@_isBusy"
                          OnClick="RetryVerificationAsync">
                @Labels.GdprRetryVerification
            </FluentButton>
        }
        @if (!string.IsNullOrWhiteSpace(_correlationId))
        {
            <p>@Labels.GdprCorrelationId: @_correlationId</p>
            @if (EventStoreLinks.BuildCorrelationLink(_correlationId) is { } correlationLink)
            {
                <a href="@correlationLink" target="_blank" rel="noopener noreferrer">@Labels.OpenEventStoreCorrelation</a>
            }
            else
            {
                <FluentButton Appearance="ButtonAppearance.Outline" Disabled="true">
                    @Labels.EventStoreAdminUnavailable
                </FluentButton>
            }
        }
    </section>

    <ErasureStatusPanel Status="_erasureStatus"
                        Certificate="_erasureCertificate"
                        Labels="Labels"
                        InstanceId="@_instanceId" />

    <RestrictionActionsPanel Labels="Labels"
                             InstanceId="@_instanceId"
                             Reason="@_restrictionReason"
                             ReasonChanged="value => _restrictionReason = value"
                             CanRestrict="@CanRestrict"
                             CanLift="@CanLiftRestriction"
                             Restrict="RestrictAsync"
                             Lift="LiftRestrictionAsync" />

    <ConsentManagementPanel Labels="Labels"
                            InstanceId="@_instanceId"
                            ConsentRecords="@ConsentRecords"
                            ChannelId="@_consentChannelId"
                            ChannelIdChanged="value => _consentChannelId = value"
                            Purpose="@_consentPurpose"
                            PurposeChanged="value => _consentPurpose = value"
                            LawfulBasisValue="@_lawfulBasisValue"
                            LawfulBasisValueChanged="value => _lawfulBasisValue = value"
                            LawfulBasisOptions="@_lawfulBasisOptions"
                            CanAdd="@CanAddConsent"
                            CanRevoke="@(!_isBusy)"
                            Add="AddConsentAsync"
                            Revoke="RevokeConsentAsync" />

    <PortabilityExportPanel Labels="Labels"
                            InstanceId="@_instanceId"
                            CanExport="@CanExport"
                            FileName="@_exportFileName"
                            Export="ExportAsync" />

    <ProcessingRecordsPanel Labels="Labels"
                            InstanceId="@_instanceId"
                            Records="@_processingRecords"
                            Refresh="LoadProcessingRecordsAsync" />
</section>

@code {
    private readonly string[] _lawfulBasisOptions = Enum.GetNames<LawfulBasis>();
    private readonly string _instanceId = Guid.NewGuid().ToString("N").Substring(0, 8);
    private IReadOnlyList<ProcessingActivityRecord> _processingRecords = [];
    private PartyErasureStatusRecord? _erasureStatus;
    private ErasureCertificate? _erasureCertificate;
    private string? _previousPartyId;
    private string? _correlationId;
    private string? _restrictionReason;
    private string? _consentChannelId;
    private string? _consentPurpose;
    private string _lawfulBasisValue = LawfulBasis.Consent.ToString();
    private string? _exportFileName;
    private AdminPortalGdprOutcome? _lastOutcome;
    private AdminPortalGdprOutcome? _focusedOutcome;
    private bool _confirmErasure;
    private bool _isBusy;
    private CancellationTokenSource? _cts;
    private ElementReference _operationsHeading;

    [Parameter, EditorRequired]
    public PartyDetail Party { get; set; } = default!;

    [Parameter, EditorRequired]
    public AdminPortalLabels Labels { get; set; } = new();

    [Parameter]
    public string? TenantContextSignature { get; set; }

    [Parameter]
    public EventCallback RefreshParty { get; set; }

    private IReadOnlyList<ConsentRecord> ConsentRecords
        => Party.ConsentRecords ?? [];

    private string OperationMessage
        => _lastOutcome switch
        {
            AdminPortalGdprOutcome.Accepted => Labels.GdprOperationAccepted,
            AdminPortalGdprOutcome.Completed => Labels.GdprOperationCompleted,
            AdminPortalGdprOutcome.ValidationRejected => Labels.GdprOperationRejected,
            AdminPortalGdprOutcome.Forbidden => Labels.AccessDenied,
            AdminPortalGdprOutcome.MissingTenant => Labels.TenantUnavailable,
            AdminPortalGdprOutcome.ErasureInProgress => Labels.GdprDpoPendingErasure,
            AdminPortalGdprOutcome.Erased => Labels.GdprTerminalErased,
            AdminPortalGdprOutcome.TransientFailure => Labels.TransientFailure,
            AdminPortalGdprOutcome.AuthenticationRequired => Labels.SignInRequired,
            AdminPortalGdprOutcome.NotFound => Labels.GdprOperationNotFound,
            AdminPortalGdprOutcome.ContractUnavailable => Labels.GdprOperationContractUnavailable,
            AdminPortalGdprOutcome.Unknown => Labels.GdprOperationFailed,
            _ => Labels.GdprOperationFailed,
        };

    private bool IsErasurePending
        => Party.IsErased || _erasureStatus?.Status is "ErasurePending" or "KeyDestroyed" or "VerificationInProgress" or "Verified";

    private bool CanRequestErasure
        => !_isBusy && !Party.IsErased && !IsErasurePending;

    private bool CanRestrict
        => !_isBusy && !Party.IsRestricted && !Party.IsErased && !IsErasurePending;

    private bool CanLiftRestriction
        => !_isBusy && Party.IsRestricted && !Party.IsErased;

    private bool CanAddConsent
        => !_isBusy
            && !Party.IsErased
            && !IsErasurePending
            && !string.IsNullOrWhiteSpace(_consentChannelId)
            && !string.IsNullOrWhiteSpace(_consentPurpose);

    private bool CanExport
        => !_isBusy && !Party.IsErased && !IsErasurePending;

    private bool CanRetryVerification
        => !_isBusy && _erasureStatus?.Status is "VerificationPartial" or "VerificationFailed" or "Partial" or "Failed";

    protected override void OnInitialized() => _cts = new CancellationTokenSource();

    protected override void OnParametersSet()
    {
        if (!string.Equals(_previousPartyId, Party.Id, StringComparison.Ordinal))
        {
            // Cancel any in-flight requests bound to the previous party so their continuations
                // do not mutate state that now refers to a different party.
            CancelInFlight();
            _cts = new CancellationTokenSource();
            _previousPartyId = Party.Id;
            _confirmErasure = false;
            _correlationId = null;
            _erasureStatus = null;
            _erasureCertificate = null;
            _processingRecords = [];
            _exportFileName = null;
            _lastOutcome = null;
            _focusedOutcome = null;
            GdprCoordinator.Track(TenantContextSignature, Party.Id);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_lastOutcome is not null && _lastOutcome != _focusedOutcome)
        {
            _focusedOutcome = _lastOutcome;
            try
            {
                await _operationsHeading.FocusAsync().ConfigureAwait(false);
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnect: nothing to focus on.
            }
            catch (JSException)
            {
                // Element not yet rendered or detached; outcome status announcement still fires via aria-live.
            }
        }
    }

    public void Dispose()
    {
        CancelInFlight();
    }

    private void CancelInFlight()
    {
        try
        {
            _cts?.Cancel();
        }
        catch (ObjectDisposedException)
        {
        }

        _cts?.Dispose();
        _cts = null;
    }

    private CancellationToken Token => _cts?.Token ?? CancellationToken.None;

    private void BeginErasureConfirmation()
    {
        _confirmErasure = true;
        _lastOutcome = null;
    }

    private void CancelErasure() => _confirmErasure = false;

    private async Task ConfirmErasureAsync()
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .RequestErasureAsync(partyId, token)
                .ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, token))
            {
                return result;
            }

            _confirmErasure = false;
            await RefreshErasureStatusAsync().ConfigureAwait(false);
            return result;
        }).ConfigureAwait(false);
    }

    private async Task RefreshErasureStatusAsync()
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        await RunQueryAsync(async () =>
        {
            PartyErasureStatusRecord? status = await QueryService.ApiClient
                .GetErasureStatusAsync(partyId, token)
                .ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, token))
            {
                return;
            }

            _erasureStatus = status;
            if (status?.Status is "Verified" or "Complete" or "Erased")
            {
                ErasureCertificate? certificate = await QueryService.ApiClient
                    .GetErasureCertificateAsync(partyId, token)
                    .ConfigureAwait(false);
                if (!IsCurrentOperation(partyId, tenantSignature, token))
                {
                    return;
                }

                _erasureCertificate = certificate;
            }
        }).ConfigureAwait(false);
    }

    private async Task RetryVerificationAsync()
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .RetryErasureVerificationAsync(partyId, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, token))
            {
                await RefreshErasureStatusAsync().ConfigureAwait(false);
            }

            return result;
        }).ConfigureAwait(false);
    }

    private async Task RestrictAsync()
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .RestrictProcessingAsync(partyId, _restrictionReason, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, token))
            {
                await RefreshParty.InvokeAsync().ConfigureAwait(false);
            }

            return result;
        }).ConfigureAwait(false);
    }

    private async Task LiftRestrictionAsync()
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .LiftRestrictionAsync(partyId, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, token))
            {
                await RefreshParty.InvokeAsync().ConfigureAwait(false);
            }

            return result;
        }).ConfigureAwait(false);
    }

    private async Task AddConsentAsync()
    {
        if (!Enum.TryParse(_lawfulBasisValue, out LawfulBasis lawfulBasis))
        {
            lawfulBasis = LawfulBasis.Consent;
        }

        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .AddConsentAsync(partyId, _consentChannelId!, _consentPurpose!, lawfulBasis, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, token))
            {
                await RefreshParty.InvokeAsync().ConfigureAwait(false);
            }

            return result;
        }).ConfigureAwait(false);
    }

    private async Task RevokeConsentAsync(string consentId)
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .RevokeConsentAsync(partyId, consentId, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, token))
            {
                await RefreshParty.InvokeAsync().ConfigureAwait(false);
            }

            return result;
        }).ConfigureAwait(false);
    }

    private async Task ExportAsync()
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        await RunQueryAsync(async () =>
        {
            AdminPortalExportDownload export = await QueryService.ApiClient
                .ExportPartyDataAsync(partyId, token)
                .ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, token))
            {
                return;
            }

            // Defense-in-depth: re-derive the download filename from non-PII components
            // rather than trusting the transport-supplied FileName. Resolved 2026-05-10 (D2).
            string safeFileName = GdprExportFileNameBuilder.Build(partyId, DateTimeOffset.UtcNow);
            if (export.Payload.Length == 0)
            {
                _exportFileName = null;
                throw new AdminPortalQueryException(AdminPortalQueryFailureKind.TransientFailure);
            }

            try
            {
                await JsRuntime.InvokeVoidAsync(
                    "HexalithPartiesAdminPortal.downloadJson",
                    safeFileName,
                    export.ContentType,
                    Convert.ToBase64String(export.Payload)).ConfigureAwait(false);
                _exportFileName = safeFileName;
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnect: drop the export silently; the operator's session is gone.
                _exportFileName = null;
                throw new AdminPortalQueryException(AdminPortalQueryFailureKind.TransientFailure);
            }
            catch (JSException)
            {
                // Host did not register the download helper — surface a transient failure
                // rather than implying the export completed.
                _exportFileName = null;
                throw new AdminPortalQueryException(AdminPortalQueryFailureKind.TransientFailure);
            }
        }).ConfigureAwait(false);
    }

    private async Task LoadProcessingRecordsAsync()
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        await RunQueryAsync(async () =>
        {
            IReadOnlyList<ProcessingActivityRecord> records = await QueryService.ApiClient
                .GetProcessingRecordsAsync(partyId, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, token))
            {
                _processingRecords = records;
            }
        }).ConfigureAwait(false);
    }

    private async Task RunCommandAsync(Func<Task<AdminPortalGdprCommandResult>> action)
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        _isBusy = true;
        try
        {
            AdminPortalGdprCommandResult result = await action().ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, token))
            {
                return;
            }

            _lastOutcome = result.Outcome;
            // Refresh correlation per command so auditors see the most recent operation,
            // not the first one ever recorded for this party.
            if (!string.IsNullOrWhiteSpace(result.CorrelationId))
            {
                _correlationId = result.CorrelationId;
            }
        }
        catch (AdminPortalQueryException ex)
        {
            if (!IsCurrentOperation(partyId, tenantSignature, token))
            {
                return;
            }

            _lastOutcome = OutcomeFromFailure(ex.Kind);
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
            // Component disposed or party changed mid-flight; drop result silently.
        }
        finally
        {
            if (IsCurrentOperation(partyId, tenantSignature, token))
            {
                _isBusy = false;
            }
        }
    }

    private async Task RunQueryAsync(Func<Task> action)
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        _isBusy = true;
        try
        {
            await action().ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, token))
            {
                return;
            }

            _lastOutcome = AdminPortalGdprOutcome.Completed;
        }
        catch (AdminPortalQueryException ex)
        {
            if (!IsCurrentOperation(partyId, tenantSignature, token))
            {
                return;
            }

            _lastOutcome = OutcomeFromFailure(ex.Kind);
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
            // Component disposed or party changed mid-flight; drop result silently.
        }
        finally
        {
            if (IsCurrentOperation(partyId, tenantSignature, token))
            {
                _isBusy = false;
            }
        }
    }

    private bool IsCurrentOperation(string partyId, string? tenantSignature, CancellationToken token)
        => !token.IsCancellationRequested
            && string.Equals(Party.Id, partyId, StringComparison.Ordinal)
            && string.Equals(TenantContextSignature, tenantSignature, StringComparison.Ordinal);

    private static AdminPortalGdprOutcome OutcomeFromFailure(AdminPortalQueryFailureKind kind)
        => kind switch
        {
            AdminPortalQueryFailureKind.AuthenticationRequired => AdminPortalGdprOutcome.AuthenticationRequired,
            AdminPortalQueryFailureKind.TenantRequired => AdminPortalGdprOutcome.MissingTenant,
            AdminPortalQueryFailureKind.Forbidden => AdminPortalGdprOutcome.Forbidden,
            AdminPortalQueryFailureKind.NotFound => AdminPortalGdprOutcome.NotFound,
            AdminPortalQueryFailureKind.Conflict => AdminPortalGdprOutcome.ErasureInProgress,
            AdminPortalQueryFailureKind.Gone => AdminPortalGdprOutcome.Erased,
            AdminPortalQueryFailureKind.Validation => AdminPortalGdprOutcome.ValidationRejected,
            AdminPortalQueryFailureKind.TransientFailure => AdminPortalGdprOutcome.TransientFailure,
            AdminPortalQueryFailureKind.ContractUnavailable => AdminPortalGdprOutcome.ContractUnavailable,
            _ => AdminPortalGdprOutcome.Unknown,
        };
}
