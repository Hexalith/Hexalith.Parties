@implements IDisposable
@inject AdminPortalPartyQueryService QueryService
@inject AdminPortalEventStoreAdminLinks EventStoreLinks
@inject AdminPortalGdprStateCoordinator GdprCoordinator
@inject IJSRuntime JsRuntime

<section aria-labelledby="@($"gdpr-operations-heading-{_instanceId}")">
    <h3 id="@($"gdpr-operations-heading-{_instanceId}")"
        tabindex="-1"
        data-primary-destination="@(AutoFocusOperations ? "gdpr" : null)"
        @ref="_operationsHeading">@Labels.GdprOperations</h3>
    <p role="@OperationAnnouncementRole"
       aria-live="@OperationAnnouncementPoliteness"
       tabindex="@OperationAnnouncementTabIndex"
       data-gdpr-operation-announcement
       @ref="_operationAnnouncement">
        @OperationMessage
    </p>

    <DpoOperationalSummaryPanel Party="Party"
                                Labels="Labels"
                                InstanceId="@_instanceId"
                                IsErasurePending="@IsErasurePending"
                                ProcessingRecordCount="@_processingRecords.Count" />

    <section aria-labelledby="@($"erasure-actions-heading-{_instanceId}")">
        <h4 id="@($"erasure-actions-heading-{_instanceId}")">@Labels.RequestErasure</h4>
        @if (_confirmErasure)
        {
            <FluentDialog Modal="true"
                          role="dialog"
                          aria-modal="true"
                          aria-labelledby="@ErasureDialogTitleId"
                          @onkeydown="HandleErasureDialogKeyDownAsync">
                <FluentDialogBody>
                    <TitleTemplate>
                        <span id="@ErasureDialogTitleId">@Labels.GdprEraseDialogTitle</span>
                    </TitleTemplate>
                    <ChildContent>
                        <div class="hx-parties-admin__erasure-dialog">
                            <p id="@ErasureWarningId">@Labels.GdprErasureWarning</p>
                            <FluentTextInput Id="@ErasureInputId"
                                             Value="@_erasureTypedName"
                                             ValueChanged="OnErasureTypedNameChanged"
                                             TextInputType="TextInputType.Text"
                                             Label="@Labels.GdprEraseConfirmationInputLabel"
                                             aria-describedby="@ErasureWarningId"
                                             autocomplete="off"
                                             autofocus="true" />
                            <p>@Labels.GdprEraseConfirmationHelp</p>
                            <p role="status"
                               aria-live="polite"
                               data-erasure-confirmation-live>
                                @_erasureEnablementAnnouncement
                            </p>
                        </div>
                    </ChildContent>
                    <ActionTemplate>
                        <FluentButton Appearance="ButtonAppearance.Outline"
                                      Disabled="@_isBusy"
                                      OnClick="CancelErasure">
                            @Labels.GdprCancel
                        </FluentButton>
                        <FluentButton Appearance="ButtonAppearance.Primary"
                                      Class="hx-parties-admin__danger-action"
                                      Disabled="@(!CanConfirmErasure)"
                                      aria-disabled="@(!CanConfirmErasure)"
                                      OnClick="ConfirmErasureAsync">
                            @Labels.GdprConfirmErasure
                        </FluentButton>
                    </ActionTemplate>
                </FluentDialogBody>
            </FluentDialog>
        }
        else
        {
            <FluentButton Appearance="ButtonAppearance.Outline"
                          Disabled="@(!CanRequestErasure)"
                          OnClick="BeginErasureConfirmation">
                @Labels.RequestErasure
            </FluentButton>
        }
        <FluentButton Appearance="ButtonAppearance.Outline"
                      Disabled="@(!CanRefreshErasureStatus)"
                      OnClick="RefreshErasureStatusFromUiAsync">
            @Labels.GdprRefreshStatus
        </FluentButton>
        @if (!string.IsNullOrWhiteSpace(ErasureDisabledReason))
        {
            <p role="status" aria-live="polite">@ErasureDisabledReason</p>
        }
        @if (CanRetryVerification)
        {
            <FluentButton Appearance="ButtonAppearance.Outline"
                          Disabled="@_isBusy"
                          OnClick="RetryVerificationAsync">
                @Labels.GdprRetryVerification
            </FluentButton>
        }
        @if (!string.IsNullOrWhiteSpace(_correlationId))
        {
            <p>@Labels.GdprCorrelationId: @_correlationId</p>
            @if (EventStoreLinks.BuildCorrelationLink(_correlationId) is { } correlationLink)
            {
                <a href="@correlationLink" target="_blank" rel="noopener noreferrer">@Labels.OpenEventStoreCorrelation</a>
            }
            else
            {
                <FluentButton Appearance="ButtonAppearance.Outline" Disabled="true">
                    @Labels.EventStoreAdminUnavailable
                </FluentButton>
            }
        }
    </section>

    <ErasureStatusPanel Status="_erasureStatus"
                        Certificate="_erasureCertificate"
                        Labels="Labels"
                        InstanceId="@_instanceId" />

    <RestrictionActionsPanel Labels="Labels"
                             InstanceId="@_instanceId"
                             Reason="@_restrictionReason"
                             ReasonChanged="value => _restrictionReason = value"
                             CanRestrict="@CanRestrict"
                             CanLift="@CanLiftRestriction"
                             DisabledReason="@RestrictionDisabledReason"
                             Restrict="RestrictAsync"
                             Lift="LiftRestrictionAsync" />

    <ConsentManagementPanel Labels="Labels"
                            InstanceId="@_instanceId"
                            ConsentRecords="@ConsentRecords"
                            ChannelId="@_consentChannelId"
                            ChannelIdChanged="value => _consentChannelId = value"
                            Purpose="@_consentPurpose"
                            PurposeChanged="value => _consentPurpose = value"
                            LawfulBasisValue="@_lawfulBasisValue"
                            LawfulBasisValueChanged="value => _lawfulBasisValue = value"
                            LawfulBasisOptions="@_lawfulBasisOptions"
                            CanAdd="@CanAddConsent"
                            CanRevoke="@CanRevokeConsent"
                            DisabledReason="@ConsentDisabledReason"
                            Add="AddConsentAsync"
                            Revoke="RevokeConsentAsync" />

    <PortabilityExportPanel Labels="Labels"
                            InstanceId="@_instanceId"
                            CanExport="@CanExport"
                            FileName="@_exportFileName"
                            DisabledReason="@ExportDisabledReason"
                            Export="ExportAsync" />

    <ProcessingRecordsPanel Labels="Labels"
                            InstanceId="@_instanceId"
                            Records="@_processingRecords"
                            CanRefresh="@CanLoadProcessingRecords"
                            DisabledReason="@ProcessingRecordsDisabledReason"
                            Refresh="LoadProcessingRecordsAsync" />
</section>

@code {
    private const string GdprExportContentType = "application/json";

    private readonly string[] _lawfulBasisOptions = Enum.GetNames<LawfulBasis>();
    private readonly string _instanceId = Guid.NewGuid().ToString("N").Substring(0, 8);
    private IReadOnlyList<ProcessingActivityRecord> _processingRecords = [];
    private PartyErasureStatusRecord? _erasureStatus;
    private ErasureCertificate? _erasureCertificate;
    private string? _previousPartyId;
    private string? _gdprCapabilityPartyId;
    private string? _gdprCapabilityTenantSignature;
    private string? _correlationId;
    private string? _restrictionReason;
    private string? _consentChannelId;
    private string? _consentPurpose;
    private string _lawfulBasisValue = LawfulBasis.Consent.ToString();
    private string? _exportFileName;
    private AdminPortalGdprCapability _gdprCapability = AdminPortalGdprCapability.Unavailable();
    private AdminPortalGdprOutcome? _lastOutcome;
    private AdminPortalGdprOutcome? _focusedOutcome;
    private bool _focusedInitialOperations;
    private long _capabilityVersion;
    private bool _confirmErasure;
    private bool _erasureMatchAnnounced;
    private bool _isBusy;
    private string? _erasureEnablementAnnouncement;
    private string? _erasureTypedName;
    private CancellationTokenSource? _cts;
    private ElementReference _operationsHeading;
    private ElementReference _operationAnnouncement;

    [Parameter, EditorRequired]
    public PartyDetail Party { get; set; } = default!;

    [Parameter, EditorRequired]
    public AdminPortalLabels Labels { get; set; } = new();

    [Parameter]
    public string? TenantContextSignature { get; set; }

    [Parameter]
    public EventCallback RefreshParty { get; set; }

    [Parameter]
    public bool AutoFocusOperations { get; set; }

    private IReadOnlyList<ConsentRecord> ConsentRecords
        => Party.ConsentRecords ?? [];

    private string OperationMessage
        => _lastOutcome switch
        {
            AdminPortalGdprOutcome.Accepted => Labels.GdprOperationAccepted,
            AdminPortalGdprOutcome.Completed => Labels.GdprOperationCompleted,
            AdminPortalGdprOutcome.ValidationRejected => Labels.GdprOperationRejected,
            AdminPortalGdprOutcome.Forbidden => Labels.AccessDenied,
            AdminPortalGdprOutcome.MissingTenant => Labels.TenantUnavailable,
            AdminPortalGdprOutcome.ErasureInProgress => Labels.GdprDpoPendingErasure,
            AdminPortalGdprOutcome.Erased => Labels.GdprTerminalErased,
            AdminPortalGdprOutcome.TransientFailure => Labels.TransientFailure,
            AdminPortalGdprOutcome.AuthenticationRequired => Labels.SignInRequired,
            AdminPortalGdprOutcome.NotFound => Labels.GdprOperationNotFound,
            AdminPortalGdprOutcome.ContractUnavailable => Labels.GdprOperationContractUnavailable,
            AdminPortalGdprOutcome.Unknown => Labels.GdprOperationFailed,
            _ => string.Empty,
        };

    private string OperationAnnouncementRole
        => IsAssertiveOutcome(_lastOutcome) ? "alert" : "status";

    private string OperationAnnouncementPoliteness
        => IsAssertiveOutcome(_lastOutcome) ? "assertive" : "polite";

    private string? OperationAnnouncementTabIndex
        => IsAssertiveOutcome(_lastOutcome) ? "-1" : null;

    private bool IsErasurePending
        => Party.IsErased
            || _erasureStatus?.Status is "ErasurePending" or "KeyDestroyed" or "VerificationInProgress" or "Verified" or "Complete" or "Erased";

    private bool CanRequestErasure
        => _gdprCapability.CanRequestErasure && !_isBusy && !Party.IsErased && !IsErasurePending;

    private bool CanConfirmErasure
        => CanRequestErasure && HasMatchingErasureConfirmation;

    private bool HasMatchingErasureConfirmation
        => !string.IsNullOrEmpty(Party.DisplayName)
            && string.Equals(_erasureTypedName, Party.DisplayName, StringComparison.Ordinal);

    private bool CanRefreshErasureStatus
        => _gdprCapability.CanReadErasureStatus && !_isBusy;

    private bool CanRestrict
        => _gdprCapability.CanRestrictProcessing && !_isBusy && !Party.IsRestricted && !Party.IsErased && !IsErasurePending;

    private bool CanLiftRestriction
        => _gdprCapability.CanLiftRestriction && !_isBusy && Party.IsRestricted && !Party.IsErased && !IsErasurePending;

    private bool CanAddConsent
        => _gdprCapability.CanManageConsent
            && !_isBusy
            && !Party.IsErased
            && !IsErasurePending
            && !string.IsNullOrWhiteSpace(_consentChannelId)
            && !string.IsNullOrWhiteSpace(_consentPurpose);

    private bool CanRevokeConsent
        => _gdprCapability.CanManageConsent && !_isBusy && !Party.IsErased && !IsErasurePending;

    private bool CanExport
        => _gdprCapability.CanExportData && !_isBusy && !Party.IsErased && !IsErasurePending;

    private bool CanRetryVerification
        => _gdprCapability.CanRetryVerification
            && !_isBusy
            && _erasureStatus?.Status is "VerificationPartial" or "VerificationFailed" or "Partial" or "Failed";

    private bool CanLoadProcessingRecords
        => _gdprCapability.CanReadProcessingRecords && !_isBusy;

    private string? ErasureDisabledReason
        => _gdprCapability.CanRequestErasure
            && _gdprCapability.CanReadErasureStatus
            && _gdprCapability.CanReadErasureCertificate
            && _gdprCapability.CanRetryVerification
            ? null
            : CapabilityReason;

    private string? RestrictionDisabledReason
        => _gdprCapability.CanRestrictProcessing && _gdprCapability.CanLiftRestriction ? null : CapabilityReason;

    private string? ConsentDisabledReason
        => _gdprCapability.CanManageConsent ? null : CapabilityReason;

    private string? ExportDisabledReason
        => _gdprCapability.CanExportData ? null : CapabilityReason;

    private string? ProcessingRecordsDisabledReason
        => _gdprCapability.CanReadProcessingRecords ? null : CapabilityReason;

    private string CapabilityReason
        => _gdprCapability.Reason == AdminPortalGdprCapability.ContractUnavailableReason
            ? Labels.GdprOperationContractBlocked
            : Labels.GdprOperationContractUnavailable;

    private string ErasureDialogTitleId => $"erasure-dialog-title-{_instanceId}";

    private string ErasureInputId => $"erasure-confirm-input-{_instanceId}";

    private string ErasureWarningId => $"erasure-warning-{_instanceId}";

    protected override void OnInitialized() => _cts = new CancellationTokenSource();

    protected override async Task OnParametersSetAsync()
    {
        if (!AutoFocusOperations)
        {
            _focusedInitialOperations = false;
        }

        if (!string.Equals(_previousPartyId, Party.Id, StringComparison.Ordinal))
        {
            // Cancel any in-flight requests bound to the previous party so their continuations
            // do not mutate state that now refers to a different party.
            CancelInFlight();
            _cts = new CancellationTokenSource();
            _previousPartyId = Party.Id;
            _focusedInitialOperations = false;
            ClearSensitiveOperationState();
            _gdprCapability = AdminPortalGdprCapability.Unavailable();
            _gdprCapabilityPartyId = null;
            _gdprCapabilityTenantSignature = null;
            _capabilityVersion++;
            GdprCoordinator.Track(TenantContextSignature, Party.Id);
        }

        await RefreshGdprCapabilityAsync().ConfigureAwait(false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (AutoFocusOperations && !_focusedInitialOperations)
        {
            _focusedInitialOperations = true;
            try
            {
                await _operationsHeading.FocusAsync().ConfigureAwait(false);
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnect: nothing to focus on.
            }
            catch (JSException)
            {
                // Element not yet rendered or detached; the heading remains keyboard reachable.
            }
        }

        if (_lastOutcome is not null && _lastOutcome != _focusedOutcome && IsAssertiveOutcome(_lastOutcome))
        {
            _focusedOutcome = _lastOutcome;
            try
            {
                await _operationAnnouncement.FocusAsync().ConfigureAwait(false);
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnect: nothing to focus on.
            }
            catch (JSException)
            {
                // Element not yet rendered or detached; outcome status announcement still fires via aria-live.
            }
        }
    }

    private async Task RefreshGdprCapabilityAsync()
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        if (string.Equals(_gdprCapabilityPartyId, partyId, StringComparison.Ordinal)
            && string.Equals(_gdprCapabilityTenantSignature, tenantSignature, StringComparison.Ordinal))
        {
            return;
        }

        CancellationToken token = Token;
        AdminPortalGdprCapability capability;
        try
        {
            capability = await QueryService.ApiClient
                .GetGdprCapabilityAsync(token)
                .ConfigureAwait(false);
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
            return;
        }
        catch (Exception ex) when (ex is AdminPortalQueryException
            or HttpRequestException
            or TimeoutException
            or System.Text.Json.JsonException
            or NotSupportedException
            or TaskCanceledException
            or OperationCanceledException)
        {
            capability = AdminPortalGdprCapability.Degraded();
        }

        if (!IsCurrentCapabilityTarget(partyId, tenantSignature, token))
        {
            return;
        }

        ApplyCapability(capability ?? AdminPortalGdprCapability.Degraded());
        _gdprCapabilityPartyId = partyId;
        _gdprCapabilityTenantSignature = tenantSignature;
    }

    private void ApplyCapability(AdminPortalGdprCapability capability)
    {
        if (capability == _gdprCapability)
        {
            return;
        }

        bool wasSupported = _gdprCapability.HasAnySupport;
        bool hadCertificateSupport = _gdprCapability.CanReadErasureCertificate;
        _gdprCapability = capability;
        _capabilityVersion++;
        if (hadCertificateSupport && !capability.CanReadErasureCertificate)
        {
            _erasureCertificate = null;
        }

        if (wasSupported && !capability.HasAnySupport)
        {
            ClearSensitiveOperationState();
        }
        else if (!capability.CanRequestErasure)
        {
            ClearErasureDialogState();
        }
    }

    private void ClearSensitiveOperationState()
    {
        ClearErasureDialogState();
        _correlationId = null;
        _restrictionReason = null;
        _consentChannelId = null;
        _consentPurpose = null;
        _lawfulBasisValue = LawfulBasis.Consent.ToString();
        _erasureStatus = null;
        _erasureCertificate = null;
        _processingRecords = [];
        _exportFileName = null;
        _lastOutcome = null;
        _focusedOutcome = null;
    }

    public void Dispose()
    {
        ClearErasureDialogState();
        CancelInFlight();
    }

    private void CancelInFlight()
    {
        try
        {
            _cts?.Cancel();
        }
        catch (ObjectDisposedException)
        {
        }

        _cts?.Dispose();
        _cts = null;
    }

    private CancellationToken Token => _cts?.Token ?? CancellationToken.None;

    private void BeginErasureConfirmation()
    {
        if (!CanRequestErasure)
        {
            return;
        }

        ClearErasureDialogState();
        _confirmErasure = true;
        _lastOutcome = null;
    }

    private void CancelErasure() => ClearErasureDialogState();

    private void OnErasureTypedNameChanged(string? value)
    {
        bool wasMatching = HasMatchingErasureConfirmation;
        _erasureTypedName = value;
        bool isMatching = HasMatchingErasureConfirmation;
        if (isMatching && !wasMatching && !_erasureMatchAnnounced)
        {
            _erasureEnablementAnnouncement = Labels.GdprEraseEnabledAnnouncement;
            _erasureMatchAnnounced = true;
        }
        else if (!isMatching)
        {
            _erasureEnablementAnnouncement = null;
            _erasureMatchAnnounced = false;
        }
    }

    private Task HandleErasureDialogKeyDownAsync(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Escape", StringComparison.Ordinal))
        {
            ClearErasureDialogState();
        }

        return Task.CompletedTask;
    }

    private void ClearErasureDialogState()
    {
        _confirmErasure = false;
        _erasureTypedName = null;
        _erasureEnablementAnnouncement = null;
        _erasureMatchAnnounced = false;
    }

    private async Task ConfirmErasureAsync()
    {
        if (!CanConfirmErasure)
        {
            return;
        }

        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .RequestErasureAsync(partyId, token)
                .ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                return result;
            }

            ClearErasureDialogState();
            await RefreshErasureStatusAsync(allowWhileBusy: true).ConfigureAwait(false);
            return result;
        }).ConfigureAwait(false);
    }

    private async Task RefreshErasureStatusAsync(bool allowWhileBusy = false)
    {
        if (!_gdprCapability.CanReadErasureStatus || (!allowWhileBusy && _isBusy))
        {
            return;
        }

        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        await RunQueryAsync(async () =>
        {
            PartyErasureStatusRecord? status = await QueryService.ApiClient
                .GetErasureStatusAsync(partyId, token)
                .ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                return;
            }

            _erasureStatus = status;
            if (IsErasurePending)
            {
                ClearErasureDialogState();
            }

            bool shouldFetchCertificate = _gdprCapability.CanReadErasureCertificate
                && status?.Status is "Verified" or "Complete" or "Erased";
            // Only fetch the certificate when the capability genuinely supports it. Against the
            // provisional bridge the certificate query is contract-unavailable, so refreshing an
            // erased party would otherwise surface a misleading failure outcome. When skipped,
            // _erasureCertificate stays null and the report panel renders the safe
            // "Certificate unavailable" fallback instead.
            if (!shouldFetchCertificate)
            {
                _erasureCertificate = null;
                return;
            }

            ErasureCertificate? certificate = await QueryService.ApiClient
                .GetErasureCertificateAsync(partyId, token)
                .ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                return;
            }

            _erasureCertificate = certificate;
        }).ConfigureAwait(false);
    }

    private Task RefreshErasureStatusFromUiAsync()
        => RefreshErasureStatusAsync();

    private async Task RetryVerificationAsync()
    {
        if (!CanRetryVerification)
        {
            return;
        }

        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .RetryErasureVerificationAsync(partyId, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                await RefreshErasureStatusAsync(allowWhileBusy: true).ConfigureAwait(false);
            }

            return result;
        }).ConfigureAwait(false);
    }

    private async Task RestrictAsync()
    {
        if (!CanRestrict)
        {
            return;
        }

        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .RestrictProcessingAsync(partyId, _restrictionReason, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                await RefreshParty.InvokeAsync().ConfigureAwait(false);
            }

            return result;
        }).ConfigureAwait(false);
    }

    private async Task LiftRestrictionAsync()
    {
        if (!CanLiftRestriction)
        {
            return;
        }

        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .LiftRestrictionAsync(partyId, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                await RefreshParty.InvokeAsync().ConfigureAwait(false);
            }

            return result;
        }).ConfigureAwait(false);
    }

    private async Task AddConsentAsync()
    {
        if (!CanAddConsent)
        {
            return;
        }

        if (!Enum.TryParse(_lawfulBasisValue, out LawfulBasis lawfulBasis))
        {
            lawfulBasis = LawfulBasis.Consent;
        }

        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .AddConsentAsync(partyId, _consentChannelId!, _consentPurpose!, lawfulBasis, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                await RefreshParty.InvokeAsync().ConfigureAwait(false);
            }

            return result;
        }).ConfigureAwait(false);
    }

    private async Task RevokeConsentAsync(string consentId)
    {
        if (!CanRevokeConsent)
        {
            return;
        }

        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        await RunCommandAsync(async () =>
        {
            AdminPortalGdprCommandResult result = await QueryService.ApiClient
                .RevokeConsentAsync(partyId, consentId, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                await RefreshParty.InvokeAsync().ConfigureAwait(false);
            }

            return result;
        }).ConfigureAwait(false);
    }

    private async Task ExportAsync()
    {
        if (!CanExport)
        {
            return;
        }

        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        await RunQueryAsync(async () =>
        {
            AdminPortalExportDownload export = await QueryService.ApiClient
                .ExportPartyDataAsync(partyId, token)
                .ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                return;
            }

            // Defense-in-depth: re-derive the download filename from non-PII components
            // rather than trusting the transport-supplied FileName. Resolved 2026-05-10 (D2).
            string safeFileName = GdprExportFileNameBuilder.Build(partyId, DateTimeOffset.UtcNow);
            if (export.Payload.Length == 0)
            {
                _exportFileName = null;
                throw new AdminPortalQueryException(AdminPortalQueryFailureKind.TransientFailure);
            }

            try
            {
                await JsRuntime.InvokeVoidAsync(
                    "HexalithPartiesAdminPortal.downloadJson",
                    safeFileName,
                    GdprExportContentType,
                    Convert.ToBase64String(export.Payload)).ConfigureAwait(false);
                _exportFileName = safeFileName;
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnect: drop the export silently; the operator's session is gone.
                _exportFileName = null;
                throw new AdminPortalQueryException(AdminPortalQueryFailureKind.TransientFailure);
            }
            catch (JSException)
            {
                // Host did not register the download helper — surface a transient failure
                // rather than implying the export completed.
                _exportFileName = null;
                throw new AdminPortalQueryException(AdminPortalQueryFailureKind.TransientFailure);
            }
        }).ConfigureAwait(false);
    }

    private async Task LoadProcessingRecordsAsync()
    {
        if (!CanLoadProcessingRecords)
        {
            return;
        }

        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        await RunQueryAsync(async () =>
        {
            IReadOnlyList<ProcessingActivityRecord> records = await QueryService.ApiClient
                .GetProcessingRecordsAsync(partyId, token)
                .ConfigureAwait(false);
            if (IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                _processingRecords = records;
            }
        }).ConfigureAwait(false);
    }

    private async Task RunCommandAsync(Func<Task<AdminPortalGdprCommandResult>> action)
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        _isBusy = true;
        try
        {
            AdminPortalGdprCommandResult result = await action().ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                return;
            }

            _lastOutcome = result.Outcome;
            // Refresh correlation per command so auditors see the most recent operation,
            // not the first one ever recorded for this party. Assertive failures must not
            // leave a stale success correlation beside the failure message.
            _correlationId = !IsAssertiveOutcome(result.Outcome) && !string.IsNullOrWhiteSpace(result.CorrelationId)
                ? result.CorrelationId
                : null;
        }
        catch (AdminPortalQueryException ex)
        {
            if (!IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                return;
            }

            _lastOutcome = OutcomeFromFailure(ex.Kind);
            _correlationId = null;
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
            // Component disposed or party changed mid-flight; drop result silently.
        }
        finally
        {
            if (IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                _isBusy = false;
            }
        }
    }

    private async Task RunQueryAsync(Func<Task> action)
    {
        string partyId = Party.Id;
        string? tenantSignature = TenantContextSignature;
        CancellationToken token = Token;
        long capabilityVersion = _capabilityVersion;
        _isBusy = true;
        try
        {
            await action().ConfigureAwait(false);
            if (!IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                return;
            }

            _lastOutcome = AdminPortalGdprOutcome.Completed;
        }
        catch (AdminPortalQueryException ex)
        {
            if (!IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                return;
            }

            _lastOutcome = OutcomeFromFailure(ex.Kind);
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
            // Component disposed or party changed mid-flight; drop result silently.
        }
        finally
        {
            if (IsCurrentOperation(partyId, tenantSignature, capabilityVersion, token))
            {
                _isBusy = false;
            }
        }
    }

    private bool IsCurrentOperation(string partyId, string? tenantSignature, long capabilityVersion, CancellationToken token)
        => !token.IsCancellationRequested
            && string.Equals(Party.Id, partyId, StringComparison.Ordinal)
            && string.Equals(TenantContextSignature, tenantSignature, StringComparison.Ordinal)
            && _capabilityVersion == capabilityVersion;

    private bool IsCurrentCapabilityTarget(string partyId, string? tenantSignature, CancellationToken token)
        => !token.IsCancellationRequested
            && string.Equals(Party.Id, partyId, StringComparison.Ordinal)
            && string.Equals(TenantContextSignature, tenantSignature, StringComparison.Ordinal);

    private static AdminPortalGdprOutcome OutcomeFromFailure(AdminPortalQueryFailureKind kind)
        => kind switch
        {
            AdminPortalQueryFailureKind.AuthenticationRequired => AdminPortalGdprOutcome.AuthenticationRequired,
            AdminPortalQueryFailureKind.TenantRequired => AdminPortalGdprOutcome.MissingTenant,
            AdminPortalQueryFailureKind.Forbidden => AdminPortalGdprOutcome.Forbidden,
            AdminPortalQueryFailureKind.NotFound => AdminPortalGdprOutcome.NotFound,
            AdminPortalQueryFailureKind.Conflict => AdminPortalGdprOutcome.ErasureInProgress,
            AdminPortalQueryFailureKind.Gone => AdminPortalGdprOutcome.Erased,
            AdminPortalQueryFailureKind.Validation => AdminPortalGdprOutcome.ValidationRejected,
            AdminPortalQueryFailureKind.TransientFailure => AdminPortalGdprOutcome.TransientFailure,
            AdminPortalQueryFailureKind.ContractUnavailable => AdminPortalGdprOutcome.ContractUnavailable,
            _ => AdminPortalGdprOutcome.Unknown,
        };

    private static bool IsAssertiveOutcome(AdminPortalGdprOutcome? outcome)
        => outcome is AdminPortalGdprOutcome.ValidationRejected
            or AdminPortalGdprOutcome.Forbidden
            or AdminPortalGdprOutcome.MissingTenant
            or AdminPortalGdprOutcome.TransientFailure
            or AdminPortalGdprOutcome.AuthenticationRequired
            or AdminPortalGdprOutcome.NotFound
            or AdminPortalGdprOutcome.Unknown;
}
