<section aria-labelledby="@($"processing-records-heading-{InstanceId}")">
    <h4 id="@($"processing-records-heading-{InstanceId}")">@Labels.GdprProcessingRecords</h4>
    <FluentButton Appearance="ButtonAppearance.Outline"
                  Disabled="@(!CanRefresh)"
                  OnClick="Refresh">
        @Labels.ProcessingRecords
    </FluentButton>
    @if (!string.IsNullOrWhiteSpace(DisabledReason))
    {
        <p role="status" aria-live="polite">@DisabledReason</p>
    }
    @if (Records.Count == 0)
    {
        <p>@Labels.GdprNoProcessingRecords</p>
    }
    else
    {
        <ol>
            @foreach (ProcessingActivityRecord record in Records.OrderBy(r => r.SequenceNumber))
            {
                <li>
                    <strong>@record.EventType</strong>
                    <dl>
                        <dt>@Labels.PartyId</dt>
                        <dd>@record.PartyId</dd>
                        <dt>@Labels.TenantId</dt>
                        <dd>@record.TenantId</dd>
                        <dt>@Labels.SequenceNumber</dt>
                        <dd>@record.SequenceNumber</dd>
                        <dt>@Labels.EventType</dt>
                        <dd>@record.EventType</dd>
                        <dt>@Labels.OperationCategory</dt>
                        <dd>@record.OperationCategory</dd>
                        <dt>@Labels.Timestamp</dt>
                        <dd>@FormatDate(record.Timestamp)</dd>
                        <dt>@Labels.ActorId</dt>
                        <dd>@record.ActorId</dd>
                        <dt>@Labels.CorrelationId</dt>
                        <dd>@record.CorrelationId</dd>
                        <dt>@Labels.Outcome</dt>
                        <dd>@record.Outcome</dd>
                        <dt>@Labels.Summary</dt>
                        <dd>@FormatSummary(record.Summary)</dd>
                    </dl>
                </li>
            }
        </ol>
    }
</section>

@code {
    private const int MaxSummaryLength = 160;

    [Parameter, EditorRequired]
    public AdminPortalLabels Labels { get; set; } = new();

    [Parameter]
    public string InstanceId { get; set; } = Guid.NewGuid().ToString("N");

    [Parameter]
    public IReadOnlyList<ProcessingActivityRecord> Records { get; set; } = [];

    [Parameter]
    public bool CanRefresh { get; set; } = true;

    [Parameter]
    public string? DisabledReason { get; set; }

    [Parameter]
    public EventCallback Refresh { get; set; }

    private string FormatDate(DateTimeOffset date)
        => date == default
            ? Labels.MissingDate
            : date.ToString("g", System.Globalization.CultureInfo.CurrentCulture);

    private static string FormatSummary(string? summary)
    {
        if (string.IsNullOrWhiteSpace(summary))
        {
            return string.Empty;
        }

        string trimmed = summary.Trim();
        return trimmed.Length <= MaxSummaryLength
            ? trimmed
            : trimmed[..MaxSummaryLength] + "...";
    }
}
