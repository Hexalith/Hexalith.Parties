<section aria-labelledby="@($"consent-management-heading-{InstanceId}")">
    <h4 id="@($"consent-management-heading-{InstanceId}")">@Labels.ConsentRecords</h4>
    <div class="hx-parties-admin__gdpr-form">
        <FluentTextInput Value="@ChannelId"
                         ValueChanged="ChannelIdChanged"
                         Label="@Labels.GdprChannelId"
                         aria-label="@Labels.GdprChannelId" />
        <FluentTextInput Value="@Purpose"
                         ValueChanged="PurposeChanged"
                         Label="@Labels.GdprPurpose"
                         aria-label="@Labels.GdprPurpose" />
        <FluentSelect TOption="string" TValue="string"
                      Items="@LawfulBasisOptions"
                      Value="@LawfulBasisValue"
                      ValueChanged="LawfulBasisValueChanged"
                      OptionText="Labels.LawfulBasisLabel"
                      Label="@Labels.GdprLawfulBasis"
                      aria-label="@Labels.GdprLawfulBasis" />
        <FluentButton Appearance="ButtonAppearance.Outline"
                      Disabled="@(!CanAdd)"
                      OnClick="Add">
            @Labels.AddConsent
        </FluentButton>
    </div>
    @if (!string.IsNullOrWhiteSpace(DisabledReason))
    {
        <p role="status" aria-live="polite">@DisabledReason</p>
    }

    @if (ConsentRecords.Count == 0)
    {
        <p>@Labels.NoConsentRecords</p>
    }
    else
    {
        <ul>
            @foreach (ConsentRecord consent in ConsentRecords)
            {
                <li>
                    @Labels.ConsentPurposeLabel(consent.Purpose): @Labels.LawfulBasisLabel(consent.LawfulBasis.ToString())
                    (@(consent.IsActive ? Labels.ConsentActive : Labels.ConsentRevoked))
                    <dl>
                        <dt>@Labels.ChangedAt</dt>
                        <dd>@FormatDate(consent.GrantedAt)</dd>
                        @if (!consent.IsActive)
                        {
                            <dt>@Labels.Revoked</dt>
                            <dd>@FormatNullableDate(consent.RevokedAt)</dd>
                        }
                    </dl>
                    @if (consent.IsActive)
                    {
                        <FluentButton Appearance="ButtonAppearance.Subtle"
                                      Disabled="@(!CanRevoke)"
                                      OnClick="@(() => BeginRevokeConfirmation(consent.ConsentId))">
                            @Labels.RevokeConsent
                        </FluentButton>
                        @if (string.Equals(_pendingRevokeConsentId, consent.ConsentId, StringComparison.Ordinal))
                        {
                            <div class="hx-parties-admin__gdpr-confirmation" role="group" aria-labelledby="@RevokeConfirmationTitleId">
                                <p id="@RevokeConfirmationTitleId">@Labels.GdprConfirmRevokeConsentTitle</p>
                                <p>@Labels.GdprConfirmRevokeConsentMessage</p>
                                <p role="status" aria-live="polite" data-gdpr-confirmation-live>@Labels.GdprConfirmationOpened</p>
                                <div class="hx-parties-admin__gdpr-actions">
                                    <FluentButton Appearance="ButtonAppearance.Outline"
                                                  Disabled="@(!CanRevoke)"
                                                  OnClick="CancelRevokeConfirmation">
                                        @Labels.GdprCancel
                                    </FluentButton>
                                    <FluentButton Appearance="ButtonAppearance.Outline"
                                                  Disabled="@(!CanRevoke)"
                                                  OnClick="ConfirmRevokeAsync">
                                        @Labels.GdprConfirm
                                    </FluentButton>
                                </div>
                            </div>
                        }
                    }
                </li>
            }
        </ul>
    }
</section>

@code {
    private string? _previousResetKey;
    private string? _pendingRevokeConsentId;

    [Parameter, EditorRequired]
    public AdminPortalLabels Labels { get; set; } = new();

    [Parameter]
    public string InstanceId { get; set; } = Guid.NewGuid().ToString("N");

    [Parameter]
    public string? ResetKey { get; set; }

    [Parameter]
    public IReadOnlyList<ConsentRecord> ConsentRecords { get; set; } = [];

    [Parameter]
    public string? ChannelId { get; set; }

    [Parameter]
    public EventCallback<string?> ChannelIdChanged { get; set; }

    [Parameter]
    public string? Purpose { get; set; }

    [Parameter]
    public EventCallback<string?> PurposeChanged { get; set; }

    [Parameter]
    public string LawfulBasisValue { get; set; } = LawfulBasis.Consent.ToString();

    [Parameter]
    public EventCallback<string> LawfulBasisValueChanged { get; set; }

    [Parameter]
    public IReadOnlyList<string> LawfulBasisOptions { get; set; } = [];

    [Parameter]
    public bool CanAdd { get; set; }

    [Parameter]
    public bool CanRevoke { get; set; }

    [Parameter]
    public string? DisabledReason { get; set; }

    [Parameter]
    public EventCallback Add { get; set; }

    [Parameter]
    public EventCallback<string> Revoke { get; set; }

    protected override void OnParametersSet()
    {
        if (!string.Equals(_previousResetKey, ResetKey, StringComparison.Ordinal))
        {
            _previousResetKey = ResetKey;
            _pendingRevokeConsentId = null;
        }

        if (_pendingRevokeConsentId is not null
            && (!CanRevoke || !ConsentRecords.Any(consent =>
                consent.IsActive && string.Equals(consent.ConsentId, _pendingRevokeConsentId, StringComparison.Ordinal))))
        {
            _pendingRevokeConsentId = null;
        }
    }

    private string RevokeConfirmationTitleId => $"revoke-consent-confirm-title-{InstanceId}";

    private void BeginRevokeConfirmation(string consentId)
    {
        if (!CanRevoke)
        {
            return;
        }

        _pendingRevokeConsentId = consentId;
    }

    private void CancelRevokeConfirmation() => _pendingRevokeConsentId = null;

    private async Task ConfirmRevokeAsync()
    {
        if (_pendingRevokeConsentId is null || !CanRevoke)
        {
            return;
        }

        string consentId = _pendingRevokeConsentId;
        _pendingRevokeConsentId = null;
        await Revoke.InvokeAsync(consentId).ConfigureAwait(false);
    }

    private string FormatDate(DateTimeOffset date)
        => date == default
            ? Labels.MissingDate
            : date.ToString("g", System.Globalization.CultureInfo.CurrentCulture);

    private string FormatNullableDate(DateTimeOffset? date)
        => date is null ? Labels.MissingDate : FormatDate(date.Value);
}
