@if (Certificate is null)
{
    <p role="status" aria-live="polite">@Labels.GdprVerificationUnavailable</p>
    <p>@Labels.GdprVerificationUnavailableDetail</p>
}
else
{
    <p role="status" aria-live="polite">@VerificationMessage</p>
    <dl class="hx-parties-admin__erasure-report">
        <dt>@Labels.GdprVerificationStatus</dt>
        <dd>@Certificate.VerificationStatus</dd>
        @if (!string.IsNullOrWhiteSpace(Status?.Status))
        {
            <dt>@Labels.GdprReportStatus</dt>
            <dd>@Status.Status</dd>
        }
        <dt>@Labels.GdprReportTimestamp</dt>
        <dd>@FormatDate(Certificate.Timestamp)</dd>
        <dt>@Labels.GdprVerifiedAcrossProjections</dt>
        <dd>@FormatBoolean(IsVerified)</dd>
        <dt>@Labels.GdprKeyVersionCount</dt>
        <dd>@Certificate.KeyVersionsDestroyed.Count</dd>
    </dl>
}

@code {
    [Parameter, EditorRequired]
    public PartyErasureStatusRecord? Status { get; set; }

    [Parameter, EditorRequired]
    public ErasureCertificate? Certificate { get; set; }

    [Parameter, EditorRequired]
    public AdminPortalLabels Labels { get; set; } = new();

    private bool IsVerified
        => Certificate?.VerificationStatus == ErasureVerificationStatus.Verified
            && Status?.Status is null or "Verified" or "Complete" or "Erased";

    private string VerificationMessage
        => IsVerified ? Labels.GdprVerificationConfirmed : Labels.GdprVerificationNeedsAttention;

    private string FormatBoolean(bool value)
        => PartyDisplayFormat.FormatBoolean(value, Labels.Yes, Labels.No);

    private static string FormatDate(DateTimeOffset date)
        => date == default
            ? string.Empty
            : PartyDisplayFormat.FormatDate(
                date,
                System.Globalization.CultureInfo.CurrentCulture,
                PartyDisplayFormat.CompactDateFormat);
}
